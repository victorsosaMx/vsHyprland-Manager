# ── Hot Corners parse/build ────────────────────────────────────────────────────

# Corner keys: "hotcorner.<mon_name>.<pos>" where pos in tl,tr,bl,br
# Value: command string or "" for disabled

def parse_hotcorners(text):
    result = {
        "hotcorner.enabled":  os.path.isfile(_F_HOT),
        "hotcorner.cooldown": 1,
        "hotcorner.threshold": 5,
    }
    # Read cooldown
    m = re.search(r'^COOLDOWN\s*=\s*(\d+)', text, re.MULTILINE)
    if m:
        result["hotcorner.cooldown"] = int(m.group(1))
    m = re.search(r'^THRESHOLD\s*=\s*(\d+)', text, re.MULTILINE)
    if m:
        result["hotcorner.threshold"] = int(m.group(1))
    # Read corner blocks marked with # CORNER:<mon>:<pos>:<cmd>
    for cm in re.finditer(r'# CORNER:([^:]+):([^:]+):(.+)', text):
        mon, pos, cmd = cm.group(1).strip(), cm.group(2).strip(), cm.group(3).strip()
        result[f"hotcorner.{mon}.{pos}"] = cmd
    return result

def build_hotcorners(cfg, monitors):
    enabled   = cfg.get("hotcorner.enabled", False)
    cooldown  = cfg.get("hotcorner.cooldown", 1)
    threshold = cfg.get("hotcorner.threshold", 5)

    if not enabled:
        return None  # caller should remove/disable the script

    # Collect which corners have commands (used to know monitor names needed)
    corner_checks = []
    for m in monitors:
        name = m["name"]
        safe = name.replace("-", "_")
        for pos in ("tl", "tr", "bl", "br"):
            cmd = cfg.get(f"hotcorner.{name}.{pos}", "").strip()
            if cmd:
                corner_checks.append((name, safe, pos, cmd))

    lines = [
        "#!/bin/bash",
        "# Generated by vsHyprland-Manager — Hot Corners",
        f"COOLDOWN={cooldown}",
        f"THRESHOLD={threshold}",
        "last_trigger=0",
        "",
        "# Load monitor geometry at runtime so positions are always correct",
        "load_monitors() {",
        "    eval \"$(hyprctl monitors -j 2>/dev/null | python3 -c \"",
        "import json, sys",
        "for m in json.load(sys.stdin):",
        "    n = m['name'].replace('-','_')",
        "    print(f'{n}_X={m[\\\"x\\\"]}');   print(f'{n}_Y={m[\\\"y\\\"]}' )",
        "    print(f'{n}_W={m[\\\"width\\\"]}'); print(f'{n}_H={m[\\\"height\\\"]}')",
        "\" 2>/dev/null)\"",
        "}",
        "load_monitors",
        "",
        "while true; do",
        "    pos=$(hyprctl cursorpos 2>/dev/null)",
        "    x=$(echo \"$pos\" | awk -F',' '{print int($1)}')",
        "    y=$(echo \"$pos\" | awk -F',' '{print int($2)}')",
        "    now=$(date +%s)",
        "    diff=$((now - last_trigger))",
        "    if [[ $diff -ge $COOLDOWN ]]; then",
    ]

    for i, (name, safe, pos, cmd) in enumerate(corner_checks):
        kw = "if" if i == 0 else "elif"
        cond_map = {
            "tl": f"$x -le $(({safe}_X + $THRESHOLD)) && $y -le $(({safe}_Y + $THRESHOLD))",
            "tr": f"$x -ge $(({safe}_X + {safe}_W - $THRESHOLD)) && $y -le $(({safe}_Y + $THRESHOLD))",
            "bl": f"$x -le $(({safe}_X + $THRESHOLD)) && $y -ge $(({safe}_Y + {safe}_H - $THRESHOLD))",
            "br": f"$x -ge $(({safe}_X + {safe}_W - $THRESHOLD)) && $y -ge $(({safe}_Y + {safe}_H - $THRESHOLD))",
        }
        cond = cond_map[pos]
        lines.append(f"        {kw} [[ {cond} ]]; then")
        lines.append(f"            # CORNER:{name}:{pos}:{cmd}")
        lines.append(f"            {cmd} &")
        lines.append(f"            last_trigger=$now")
        lines.append(f"            sleep 0.8")

    if corner_checks:
        lines.append("        fi")
    lines += [
        "    fi",
        "    sleep 0.1",
        "    # Reload monitor geometry every 60s in case of hotplug",
        "    if [[ $(( $(date +%s) % 60 )) -eq 0 ]]; then load_monitors; fi",
        "done",
        "",
    ]
    return "\n".join(lines)

# ── UI helpers ─────────────────────────────────────────────────────────────────

def _lbl(text, cls="field-label"):
    l = Gtk.Label(label=text)
    l.set_xalign(0)
    l.get_style_context().add_class(cls)
    return l

def _section(text):
    b = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
    b.set_margin_top(16)
    lbl = _lbl(text, "section-title")
    b.pack_start(lbl, False, False, 0)
    sep = Gtk.Separator()
    b.pack_start(sep, False, False, 4)
    return b

def _section_lbl(text):
    """Small subsection label for use inside plugin config panels."""
    lbl = Gtk.Label()
    lbl.set_markup(f'<span weight="bold" size="small">{text}</span>')
    lbl.set_halign(Gtk.Align.START)
    lbl.set_margin_top(8)
    return lbl

def _hint(text):
    l = _lbl(text, "hint-label")
    l.set_margin_start(4)
    return l

def _spin(value, lo, hi, step=1, digits=0):
    adj = Gtk.Adjustment(
        value=value, lower=lo, upper=hi,
        step_increment=step, page_increment=step * 10
    )
    s = Gtk.SpinButton(adjustment=adj, digits=digits)
    s.set_numeric(True)
    return s

def _info_icon(tip):
    lbl = Gtk.Label()
    lbl.set_markup('<span foreground="#8c8fa1" size="10000"> ⓘ</span>')
    lbl.set_tooltip_text(tip)
    return lbl

def _slbl(text, width):
    """Label with a fixed pixel width — for aligning form columns."""
    l = _lbl(text)
    l.set_size_request(width, -1)
    return l

def _row(label_text, widget, tip=None):
    b = Gtk.Box(spacing=8)
    l = _lbl(label_text)
    l.set_size_request(180, -1)
    if tip:
        l.set_tooltip_text(tip)
        widget.set_tooltip_text(tip)
    b.pack_start(l, False, False, 0)
    b.pack_start(widget, False, False, 0)
    if tip:
        b.pack_start(_info_icon(tip), False, False, 0)
    return b

def _field(label_text, widget, tip=None):
    b = Gtk.Box(spacing=8)
    l = _lbl(label_text)
    l.set_size_request(180, -1)
    if tip:
        l.set_tooltip_text(tip)
        widget.set_tooltip_text(tip)
    b.pack_start(l, False, False, 0)
    b.pack_start(widget, True, True, 0)
    if tip:
        b.pack_start(_info_icon(tip), False, False, 0)
    return b

def _scrolled(child):
    sw = Gtk.ScrolledWindow()
    sw.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
    sw.add(child)
    return sw

def _open_url(url):
    subprocess.Popen(["xdg-open", url],
                     stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)

def _make_inner_tab(notebook, label):
    b = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=4)
    b.set_margin_start(12); b.set_margin_end(12)
    b.set_margin_top(12);   b.set_margin_bottom(12)
    notebook.append_page(b, Gtk.Label(label=label))
    return b

def _combo(options, active_text=""):
    c = Gtk.ComboBoxText()
    for o in options:
        c.append_text(o)
    if active_text in options:
        c.set_active(options.index(active_text))
    else:
        c.set_active(0)
    return c

def _switch(active):
    s = Gtk.Switch()
    s.set_active(active)
    s.set_halign(Gtk.Align.START)
    return s

def _switch_row(label, active):
    return _row(label, _switch(active))

def _check(label, active):
    cb = Gtk.CheckButton()
    cb.set_active(bool(active))
    return cb

# ── color helper ───────────────────────────────────────────────────────────────

def _color_row(label_text, cfg_key, cfg, refresh_fn, tip=None):
    """Label + swatch + entry row for Hyprland rgba colors."""
    box = Gtk.Box(spacing=8)
    lbl = _lbl(label_text)
    lbl.set_size_request(180, -1)
    if tip:
        lbl.set_tooltip_text(tip)
    box.pack_start(lbl, False, False, 0)

    color_str = cfg.get(cfg_key, "rgba(89b4faff)")

    da = Gtk.DrawingArea()
    da.set_size_request(32, 24)
    current = [color_str]

    def draw_swatch(w, cr):
        r, g, b, a = _parse_hypr_color(current[0])
        cr.set_source_rgba(r, g, b, a)
        cr.rectangle(0, 0, w.get_allocated_width(), w.get_allocated_height())
        cr.fill()

    da.connect("draw", draw_swatch)

    entry = Gtk.Entry()
    entry.set_text(color_str)
    entry.set_width_chars(24)
    entry.set_placeholder_text("rgba(rrggbbaa) or rgba(…) rgba(…) Ndeg")

    def on_entry_changed(e):
        current[0] = e.get_text()
        cfg[cfg_key] = e.get_text()
        da.queue_draw()
        refresh_fn()

    def on_swatch_click(w, event):
        cs = current[0].strip()
        if ' ' not in cs:
            dlg = Gtk.ColorChooserDialog(title="Pick color", parent=None)
            dlg.set_rgba(_hypr_to_gdk(cs))
            if dlg.run() == Gtk.ResponseType.OK:
                new_color = _gdk_to_hypr(dlg.get_rgba())
                entry.set_text(new_color)
            dlg.destroy()

    da.add_events(Gdk.EventMask.BUTTON_PRESS_MASK)
    da.connect("button-press-event", on_swatch_click)
    entry.connect("changed", on_entry_changed)

    box.pack_start(da, False, False, 0)
    box.pack_start(entry, True, True, 0)
    if tip:
        box.pack_start(_info_icon(tip), False, False, 0)
    return box, entry

# ── main class ─────────────────────────────────────────────────────────────────

class VsHyprland(Gtk.Window):

    def __init__(self):
        super().__init__(title="vsHyprland Manager")
        self.set_default_size(1000, 700)
        self.set_position(Gtk.WindowPosition.CENTER)
        self.connect("delete-event", Gtk.main_quit)
        self.connect("key-press-event", self._on_key)

        self._dark = False
        self._theme = THEME_LIGHT
        self._cfg = {}
        self._w = {}
        self._status_timer = None
        self._preview_da = None
        self._status_lbl = None
        self._css_provider = Gtk.CssProvider()
        Gtk.StyleContext.add_provider_for_screen(
            Gdk.Screen.get_default(), self._css_provider,
            Gtk.STYLE_PROVIDER_PRIORITY_USER + 200   # beat desktop-env USER-level overrides
        )

        self._apply_css()
        self._load_config()
        self._build_ui()
        self.show_all()

    def _apply_css(self):
        self._css_provider.load_from_data(_build_css(self._theme).encode())

    def _on_key(self, w, event):
        if event.state & Gdk.ModifierType.CONTROL_MASK and event.keyval == Gdk.KEY_s:
            self._on_apply()
            return True

    def _load_config(self):
        self._cfg = {}

        def read(path):
            try:
                return open(path).read()
            except Exception:
                return ""

        app_text  = read(_F_APP)
        # Animations may be embedded in appearance.conf or in a separate file
        anim_text = read(_F_ANIM)
        if not anim_text.strip():
            anim_text = app_text
        inp_text  = read(_F_INP)
        bind_text = read(_F_BINDS)
        rule_text = read(_F_RULES)
        auto_text = read(_F_AUTO)
        env_text  = read(_F_ENV)
        plug_text = read(_F_PLUG)
        mon_text  = read(_F_MON)

        self._cfg.update(parse_appearance(app_text))
        self._cfg.update(parse_animations(anim_text))
        self._cfg.update(parse_input(inp_text))
        self._cfg.update(parse_plugins(plug_text))

        # Split active border gradient into two virtual keys
        c1, c2 = _parse_border_gradient(
            self._cfg.get("general.col.active_border", "rgba(89b4faff) rgba(cba6f7ff) 0deg")
        )
        self._cfg["_border_color1"] = c1
        self._cfg["_border_color2"] = c2
        # Detect borderangle animation for animate/speed virtual keys
        ba = next(
            (a for a in self._cfg.get("animations.animations", []) if a[0] == "borderangle"),
            None
        )
        self._cfg["_border_animate"] = bool(ba and ba[1])
        self._cfg["_border_speed"]   = int(ba[2]) if ba else 8

        # Default preset selection — Smooth unless already set
        if "_active_preset" not in self._cfg:
            self._cfg["_active_preset"] = "Smooth"

        bd = parse_binds(bind_text)
        self._cfg["variables"] = bd["variables"] if (bd["variables"] or os.path.isfile(_F_BINDS)) else _DEFAULT_VARIABLES
        self._cfg["binds"]     = bd["binds"]     if (bd["binds"]     or os.path.isfile(_F_BINDS)) else _default_binds()

        rd = parse_rules(rule_text)
        if rd["windowrules"] or rd["layerrules"] or rd["blurls"] or os.path.isfile(_F_RULES):
            self._cfg["windowrules"] = rd["windowrules"]
            self._cfg["layerrules"]  = rd["layerrules"]
            self._cfg["blurls"]      = rd["blurls"]
        else:
            dr = _vs_preset_defaults("rules") or {"windowrules": [], "layerrules": [], "blurls": []}
            self._cfg["windowrules"] = [dict(r) for r in dr["windowrules"]]
            self._cfg["layerrules"]  = list(dr["layerrules"])
            self._cfg["blurls"]      = list(dr["blurls"])

        auto = parse_autostart(auto_text)
        self._cfg["autostart"] = auto if (auto or os.path.isfile(_F_AUTO)) else list(_vs_preset_defaults("autostart") or [])

        env = parse_env(env_text)
        self._cfg["env"] = env if (env or os.path.isfile(_F_ENV)) else list(_vs_preset_defaults("env") or [])

        mons = parse_monitors(mon_text)
        if mons:
            self._cfg["monitors"] = mons
        elif not os.path.isfile(_F_MON):
            self._cfg["monitors"] = [dict(_DEFAULT_MONITOR)]
        else:
            # File exists but empty/unparseable — detect from live session
            try:
                _raw_mon = subprocess.check_output(
                    ["hyprctl", "monitors", "-j"], text=True, stderr=subprocess.DEVNULL)
                self._cfg["monitors"] = [
                    {"name": m["name"],
                     "resolution": f"{m['width']}x{m['height']}",
                     "rate": round(m.get("refreshRate", 0)),
                     "pos": f"{m['x']}x{m['y']}",
                     "scale": m.get("scale", 1.0),
                     "transform": m.get("transform", 0)}
                    for m in _json.loads(_raw_mon)
                ] or [dict(_DEFAULT_MONITOR)]
            except Exception:
                self._cfg["monitors"] = [dict(_DEFAULT_MONITOR)]
        hot_text = ""
        try:
            with open(_F_HOT) as f:
                hot_text = f.read()
        except Exception:
            pass
        self._cfg.update(parse_hotcorners(hot_text))

    def _collect(self):
        w = self._w
        # Integers
        for k in (
            "general.gaps_in", "general.gaps_out", "general.border_size",
            "decoration.rounding", "shadow.range", "shadow.render_power",
            "blur.size", "blur.passes",
            "input.repeat_rate", "input.repeat_delay", "input.focus_on_close",
            "misc.force_default_wallpaper",
            "plugin.hyprexpo.columns", "plugin.hyprexpo.gap_size",
            "plugin.hyperfocus.slide_height",
            "plugin.borders-plus-plus.add_borders", "plugin.borders-plus-plus.border_size_1",
            "plugin.hyprbars.bar_height", "plugin.hyprbars.bar_text_size",
            "plugin.hyprbars.bar_padding", "plugin.hyprbars.bar_button_padding",
            "plugin.hyprbars.button_size",
            "plugin.split-monitor-workspaces.count",
            "plugin.hyprgrass.workspace_swipe_fingers", "plugin.hyprgrass.long_press_delay",
        ):
            if k in w and isinstance(w[k], Gtk.SpinButton):
                self._cfg[k] = int(w[k].get_value())
        # Floats
        for k in (
            "decoration.active_opacity", "decoration.inactive_opacity",
            "decoration.dim_strength",
            "blur.vibrancy", "input.sensitivity", "input.scroll_factor",
            "touchpad.scroll_factor", "master.mfact",
            "plugin.hyprscrolling.column_width", "plugin.hyprgrass.sensitivity",
        ):
            if k in w and isinstance(w[k], Gtk.SpinButton):
                self._cfg[k] = round(w[k].get_value(), 2)
        # Bools (Switch)
        for k in (
            "general.resize_on_border", "general.allow_tearing",
            "shadow.enabled", "blur.enabled", "xwayland.force_zero_scaling",
            "decoration.dim_inactive",
            "animations.enabled", "touchpad.natural_scroll",
            "touchpad.tap_to_click", "touchpad.disable_while_typing",
            "touchpad.drag_lock", "touchpad.middle_button_emulation",
            "input.numlock_by_default", "input.natural_scroll", "input.mouse_refocus",
            "dwindle.pseudotile", "dwindle.preserve_split",
            "dwindle.smart_split", "dwindle.smart_resizing",
            "master.new_on_top",
            "misc.disable_hyprland_logo", "misc.vfr",
            "misc.animate_manual_resizes", "misc.mouse_move_enables_dpms",
            "misc.key_press_enables_dpms",
        ):
            if k in w and isinstance(w[k], Gtk.Switch):
                self._cfg[k] = w[k].get_active()
        # Bools (CheckButton) — plugin panels use _check() → Gtk.CheckButton
        for k in (
            "plugin.borders-plus-plus.natural_rounding",
            "plugin.hyprbars.bar_blur", "plugin.hyprbars.bar_title_enabled",
            "plugin.hyprbars.bar_part_of_window", "plugin.hyprbars.bar_precedence_over_border",
            "plugin.hyprbars.icon_on_hover",
            "plugin.hyprscrolling.follow_focus",
            "plugin.hyprscrolling.fullscreen_on_one_column",
            "plugin.hyprgrass.resize_on_border_long_press",
        ):
            if k in w and isinstance(w[k], Gtk.CheckButton):
                self._cfg[k] = w[k].get_active()
        # split-monitor-workspaces uses int 0/1 (not bool)
        for k in ("plugin.split-monitor-workspaces.enable_wrapping",
                  "plugin.split-monitor-workspaces.enable_notifications"):
            if k in w and isinstance(w[k], Gtk.CheckButton):
                self._cfg[k] = 1 if w[k].get_active() else 0
        # Strings (Entry)
        for k in (
            "general.col.inactive_border",
            "shadow.color", "input.kb_layout", "input.kb_variant",
            "input.kb_options",
            "plugin.hyprexpo.bg_col", "plugin.hyprexpo.workspace_method",
            "plugin.borders-plus-plus.col.border_1", "plugin.borders-plus-plus.col.border_2",
            "plugin.hyprbars.bar_color", "plugin.hyprbars.col.text",
            "plugin.hyprbars.inactive_button_color", "plugin.hyprbars.bar_text_font",
            "plugin.hyprbars.on_double_click",
            "plugin.hyprbars.col.close_button", "plugin.hyprbars.col.minimize_button",
            "plugin.hyprbars.col.maximize_button",
            "plugin.hyprtrails.color",
            "plugin.hyprwinwrap.class",
        ):
            if k in w and isinstance(w[k], Gtk.Entry):
                val = w[k].get_text().strip()
                # XKB combos show "code — Name" — store only the code
                if k in ("input.kb_layout", "input.kb_variant") and " — " in val:
                    val = val.split(" — ")[0].strip()
                self._cfg[k] = val
        # Combos
        for k in ("general.layout", "master.new_status", "master.orientation",
                  "input.accel_profile", "plugin.hyperfocus.mode",
                  "plugin.hyprbars.bar_text_align", "plugin.hyprbars.bar_buttons_alignment"):
            if k in w and isinstance(w[k], Gtk.ComboBoxText):
                self._cfg[k] = w[k].get_active_text() or ""
        # follow_mouse combo — index IS the value (0-3)
        if "input.follow_mouse" in w and isinstance(w["input.follow_mouse"], Gtk.ComboBoxText):
            idx = w["input.follow_mouse"].get_active()
            if idx >= 0:
                self._cfg["input.follow_mouse"] = idx
        # force_split combo — index IS the value (0-2)
        if "dwindle.force_split" in w and isinstance(w["dwindle.force_split"], Gtk.ComboBoxText):
            idx = w["dwindle.force_split"].get_active()
            if idx >= 0:
                self._cfg["dwindle.force_split"] = idx
        # Compose active border from gradient virtual keys + animate control
        if "_border_animate" in self._w:
            self._cfg["_border_animate"] = self._w["_border_animate"].get_active()
        if "_border_speed" in self._w:
            self._cfg["_border_speed"] = int(self._w["_border_speed"].get_value())
        c1 = self._cfg.get("_border_color1", "rgba(89b4faff)")
        c2 = self._cfg.get("_border_color2", "rgba(cba6f7ff)")
        angle = "0deg" if self._cfg.get("_border_animate") else "45deg"
        self._cfg["general.col.active_border"] = f"{c1} {c2} {angle}"
        # Sync borderangle animation entry
        anims = list(self._cfg.get("animations.animations", []))
        ba_idx = next((i for i, a in enumerate(anims) if a[0] == "borderangle"), -1)
        ba_entry = (
            "borderangle",
            1 if self._cfg.get("_border_animate") else 0,
            self._cfg.get("_border_speed", 8),
            "linear", "loop"
        )
        if ba_idx >= 0:
            anims[ba_idx] = ba_entry
        else:
            anims.append(ba_entry)
        self._cfg["animations.animations"] = anims
        # Also update anim_store if visible so Animations tab stays in sync
        if "anim_store" in self._w:
            store = self._w["anim_store"]
            for row in store:
                if row[0] == "borderangle":
                    row[1] = ba_entry[1]
                    row[2] = ba_entry[2]
                    break
            else:
                store.append(list(ba_entry))
        self._collect_stores()
        # Hot corners
        if "hotcorner.enabled" in self._w:
            self._cfg["hotcorner.enabled"] = self._w["hotcorner.enabled"].get_active()
        if "hotcorner.cooldown" in self._w:
            self._cfg["hotcorner.cooldown"] = int(self._w["hotcorner.cooldown"].get_value())
        if "hotcorner.threshold" in self._w:
            self._cfg["hotcorner.threshold"] = int(self._w["hotcorner.threshold"].get_value())
        for key, val in self._w.get("_hotcorner_values", {}).items():
            self._cfg[key] = val

    def _collect_stores(self):
        if "bezier_store" in self._w:
            self._cfg["animations.beziers"] = [
                (r[0], float(r[1] or 0), float(r[2] or 0),
                 float(r[3] or 0), float(r[4] or 0))
                for r in self._w["bezier_store"]
            ]
        if "anim_store" in self._w:
            self._cfg["animations.animations"] = [
                (r[0], int(r[1]), int(r[2]), r[3], r[4])
                for r in self._w["anim_store"]
            ]
        if "monitor_store" in self._w:
            self._cfg["monitors"] = [
                {
                    "name": r[0], "resolution": r[1],
                    "rate": float(r[2] or 60),
                    "pos": r[3], "scale": float(r[4] or 1)
                }
                for r in self._w["monitor_store"]
            ]
        if "var_store" in self._w:
            self._cfg["variables"] = {r[0]: r[1] for r in self._w["var_store"] if r[0]}
        if "bind_store" in self._w:
            self._cfg["binds"] = [
                {
                    "type": r[0], "mods": r[1], "key": r[2],
                    "dispatcher": r[3], "params": r[4]
                }
                for r in self._w["bind_store"]
            ]
        if "wr_store" in self._w:
            keys = ("name", "match:class", "match:title", "float", "center",
                    "size", "opacity", "suppress_event")
            self._cfg["windowrules"] = [
                {k: v for k, v in zip(keys, list(r)) if v}
                for r in self._w["wr_store"]
            ]
        if "lr_store" in self._w:
            self._cfg["layerrules"] = [
                {"rule": r[0], "namespace": r[1]}
                for r in self._w["lr_store"] if r[0]
            ]
        if "bl_store" in self._w:
            self._cfg["blurls"] = [r[0] for r in self._w["bl_store"] if r[0]]
        if "auto_store" in self._w:
            self._cfg["autostart"] = [
                {"enabled": bool(r[0]), "name": r[1], "cmd": r[2]}
                for r in self._w["auto_store"] if r[2]
            ]
        if "env_store" in self._w:
            self._cfg["env"] = [(r[0], r[1]) for r in self._w["env_store"] if r[0]]

