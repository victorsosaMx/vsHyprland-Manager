        dlg.destroy()

    def _sync_preset_highlight(self):
        """Detect which preset (if any) matches current anim_store. Update buttons + label."""
        if "anim_store" not in self._w:
            return
        # Build {target: (speed, style)} ignoring borderangle
        current = {
            row[0]: (row[2], row[4])
            for row in self._w["anim_store"]
            if row[0] != "borderangle"
        }
        matched = None
        for pname, pdata in _ANIM_PRESETS.items():
            if all(current.get(a[0]) == (a[2], a[4]) for a in pdata["animations"]):
                matched = pname
                break
        self._cfg["_active_preset"] = matched
        for pname, pbtn in self._w.get("_preset_btns", {}).items():
            ctx = pbtn.get_style_context()
            if pname == matched:
                ctx.add_class("preset-active")
            else:
                ctx.remove_class("preset-active")
        if "_preset_label" in self._w:
            if matched:
                self._w["_preset_label"].set_markup(
                    f'<span foreground="{self._theme["acc"]}">● {matched}</span>'
                )
            else:
                self._w["_preset_label"].set_markup(
                    f'<span foreground="{self._theme["acc"]}">● Custom</span>'
                )

    def _load_appearance_defaults(self, *_):
        d = _APPEARANCE_DEFAULTS
        w = self._w
        # Integers
        for k in ("general.gaps_in", "general.gaps_out", "general.border_size",
                  "decoration.rounding", "shadow.range", "shadow.render_power",
                  "blur.size", "blur.passes"):
            if k in w and k in d:
                w[k].set_value(d[k])
        # Floats
        for k in ("decoration.active_opacity", "decoration.inactive_opacity",
                  "decoration.dim_strength", "blur.vibrancy"):
            if k in w and k in d:
                w[k].set_value(d[k])
        # Bools
        for k in ("general.resize_on_border", "general.allow_tearing",
                  "shadow.enabled", "blur.enabled", "xwayland.force_zero_scaling",
                  "decoration.dim_inactive"):
            if k in w and k in d:
                w[k].set_active(d[k])
        # Layout combo
        if "general.layout" in w:
            opts = ["dwindle", "master"]
            v = d.get("general.layout", "dwindle")
            if v in opts:
                w["general.layout"].set_active(opts.index(v))
        # Color entries
        for k in ("general.col.inactive_border", "shadow.color",
                  "_border_color1", "_border_color2"):
            if k in w and k in d:
                w[k].set_text(d[k])
                self._cfg[k] = d[k]
        # Border animate + speed
        if "_border_animate" in w:
            w["_border_animate"].set_active(d.get("_border_animate", True))
        if "_border_speed" in w:
            w["_border_speed"].set_value(d.get("_border_speed", 20))
        self._refresh_preview()
        self._status("Defaults loaded — click Apply to save")

    def _apply_anim_preset(self, btn, name):
        data = _ANIM_PRESETS.get(name)
        if not data:
            return
        self._cfg["_active_preset"] = name
        # Enabled switch
        if "animations.enabled" in self._w:
            self._w["animations.enabled"].set_active(data["enabled"])
        # Rebuild bezier store
        if "bezier_store" in self._w:
            self._w["bezier_store"].clear()
            for b in data["beziers"]:
                self._w["bezier_store"].append([b[0], str(b[1]), str(b[2]), str(b[3]), str(b[4])])
        # Rebuild anim store, preserving current borderangle row
        if "anim_store" in self._w:
            ba_row = next(
                (list(row) for row in self._w["anim_store"] if row[0] == "borderangle"),
                None
            )
            self._w["anim_store"].clear()
            for a in data["animations"]:
                self._w["anim_store"].append([a[0], int(a[1]), int(a[2]), a[3], a[4]])
            if ba_row:
                self._w["anim_store"].append(ba_row)
        # Sync Extra Effects widgets from the rebuilt anim_store
        def ef_val(target):
            for row in self._w["anim_store"]:
                if row[0] == target:
                    return row[2], row[4]
            return 5, ""
        def _set_combo(combo_key, vals_key, target):
            if combo_key not in self._w: return
            _, sty = ef_val(target)
            vals = self._w.get(vals_key, [])
            idx = vals.index(sty) if sty in vals else 0
            self._w[combo_key].set_active(idx)
        def _set_speed(speed_key, target):
            if speed_key not in self._w: return
            spd, _ = ef_val(target)
            self._w[speed_key].set_value(spd)
        _set_combo("_ef_open_combo",  "_ef_open_vals",  "windows")
        _set_speed("_ef_open_speed",  "windows")
        _set_combo("_ef_close_combo", "_ef_close_vals", "windowsOut")
        _set_speed("_ef_close_speed", "windowsOut")
        _set_speed("_ef_move_speed",  "windowsMove")
        _set_combo("_ef_ws_combo",    "_ef_ws_vals",    "workspaces")
        _set_speed("_ef_ws_speed",    "workspaces")
        _set_speed("_ef_sp_speed",    "specialWorkspace")
        _set_combo("_ef_ly_combo",    "_ef_ly_vals",    "layers")
        _set_speed("_ef_ly_speed",    "layers")
        _set_speed("_ef_dim_speed",   "fadeDim")
        _set_speed("_ef_fsw_speed",   "fadeSwitch")
        self._sync_preset_highlight()
        self._status(f"Preset '{name}' loaded — click Apply to save")

    def _toggle_theme(self, *_):
        current_page = self._nb.get_current_page() if hasattr(self, "_nb") else 0
        self._dark = not self._dark
        self._theme = THEME_DARK if self._dark else THEME_LIGHT
        self._apply_css()
        for child in self.get_children():
            self.remove(child)
        self._build_ui()
        self.show_all()
        self._nb.set_current_page(current_page)

