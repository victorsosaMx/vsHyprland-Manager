    def _page_monitors(self):
        t = self._theme

        def _rgb(hex_color):
            h = hex_color.lstrip("#")
            return [int(h[i:i+2], 16) / 255 for i in (0, 2, 4)]

        outer = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        outer.set_margin_start(20); outer.set_margin_end(20)
        outer.set_margin_top(14);   outer.set_margin_bottom(14)

        outer.pack_start(_section("Displays"), False, False, 0)

        # Live monitor modes from hyprctl -j
        _live_modes = {}   # {name: [(res_str, rate_float), ...]}
        try:
            raw = subprocess.check_output(
                ["hyprctl", "monitors", "-j"], text=True, stderr=subprocess.DEVNULL
            )
            for lm in _json.loads(raw):
                name = lm["name"]
                modes = []
                for mode in lm.get("availableModes", []):
                    mm = re.match(r'(\d+x\d+)@([\d.]+)Hz', mode)
                    if mm:
                        modes.append((mm.group(1), float(mm.group(2))))
                _live_modes[name] = modes
        except Exception:
            pass

        monitors = self._cfg.setdefault("monitors", [])

        # If no monitors in config, seed from live hyprctl data
        if not monitors:
            try:
                _raw = subprocess.check_output(
                    ["hyprctl", "monitors", "-j"], text=True, stderr=subprocess.DEVNULL)
                for lm in _json.loads(_raw):
                    monitors.append({
                        "name":       lm["name"],
                        "resolution": f"{lm['width']}x{lm['height']}",
                        "rate":       round(lm.get("refreshRate", 0)),
                        "pos":        f"{lm['x']}x{lm['y']}",
                        "scale":      lm.get("scale", 1.0),
                        "transform":  lm.get("transform", 0),
                    })
            except Exception:
                pass

        _sel = [0 if monitors else -1]

        # ── Visual diagram ────────────────────────────────────────────────────
        CANVAS_H = 190
        canvas = Gtk.DrawingArea()
        canvas.set_size_request(-1, CANVAS_H)
        canvas.add_events(Gdk.EventMask.BUTTON_PRESS_MASK)
        _rects = []   # [(sx, sy, sw, sh)] per monitor, in canvas pixels

        def _resolve():
            """Return list of (x, y, w, h) in logical pixels for each monitor.
            Swaps w/h for portrait transforms (1, 3, 5, 7)."""
            result = []
            auto_x = 0
            for m in monitors:
                try:    w, h = (int(v) for v in m["resolution"].split("x"))
                except Exception: w, h = 1920, 1080
                if m.get("transform", 0) in (1, 3, 5, 7):
                    w, h = h, w   # portrait: swap dimensions
                pos = m.get("pos", "auto-right")
                if pos.startswith("auto"):
                    x, y = auto_x, 0
                else:
                    try:
                        px, py = pos.split("x"); x, y = int(px), int(py)
                    except Exception:
                        x, y = auto_x, 0
                result.append((x, y, w, h))
                auto_x = x + w
            return result

        ar, ag, ab = _rgb(t["acc"])
        br, bg, bb = _rgb(t["brd"])
        tr, tg, tb = _rgb(t["txt"])
        dr, dg, db = _rgb(t["dim"])
        mr, mg, mb = _rgb(t["mid"])
        bgr, bgg, bgb = _rgb(t["bg"])
        hdr, hdg, hdb = _rgb(t["hdr"])

        def _draw(widget, cr):
            _rects.clear()
            alloc = widget.get_allocation()
            W, H = alloc.width, alloc.height
            # Background
            cr.set_source_rgb(bgr, bgg, bgb)
            cr.paint()
            if not monitors:
                cr.set_source_rgb(dr, dg, db)
                cr.set_font_size(13)
                msg = "No displays configured"
                te = cr.text_extents(msg)
                cr.move_to(W / 2 - te[2] / 2, H / 2)
                cr.show_text(msg)
                return
            positions = _resolve()
            min_x = min(p[0] for p in positions)
            min_y = min(p[1] for p in positions)
            total_w = max(p[0] + p[2] for p in positions) - min_x
            total_h = max(p[1] + p[3] for p in positions) - min_y
            PAD = 20
            scale = min((W - PAD * 2) / max(total_w, 1),
                        (H - PAD * 2) / max(total_h, 1))
            off_x = PAD + ((W - PAD * 2) - total_w * scale) / 2
            off_y = PAD + ((H - PAD * 2) - total_h * scale) / 2
            for i, (mx, my, mw, mh) in enumerate(positions):
                sx = off_x + (mx - min_x) * scale
                sy = off_y + (my - min_y) * scale
                sw = mw * scale
                sh = mh * scale
                _rects.append((sx, sy, sw, sh))
                sel     = (i == _sel[0])
                online  = monitors[i]["name"] in _live_modes

                # Fill — dimmer for offline
                if sel:
                    cr.set_source_rgba(ar, ag, ab, 0.18 if online else 0.08)
                else:
                    cr.set_source_rgba(hdr, hdg, hdb, 1.0 if online else 0.5)
                cr.rectangle(sx, sy, sw, sh)
                cr.fill()

                # Border — dashed for offline
                if sel:
                    cr.set_source_rgb(ar, ag, ab)
                    cr.set_line_width(2.5)
                else:
                    cr.set_source_rgba(br, bg, bb, 1.0 if online else 0.5)
                    cr.set_line_width(1.5)
                if not online:
                    cr.set_dash([6.0, 4.0])
                cr.rectangle(sx, sy, sw, sh)
                cr.stroke()
                cr.set_dash([])   # reset dash

                # Offline badge
                if not online:
                    badge = "offline"
                    cr.set_font_size(min(sw * 0.09, 10))
                    cr.select_font_face("monospace", cairo.FONT_SLANT_NORMAL,
                                        cairo.FONT_WEIGHT_NORMAL)
                    cr.set_source_rgba(mr, mg, mb, 0.8)
                    _bte = cr.text_extents(badge)
                    cr.move_to(sx + sw / 2 - _bte[2] / 2 - _bte[0], sy + sh * 0.14)
                    cr.show_text(badge)

                # Number (large, centered)
                num    = str(i + 1)
                fs_num = min(sw, sh) * 0.38
                cr.set_font_size(fs_num)
                cr.select_font_face("monospace", cairo.FONT_SLANT_NORMAL,
                                    cairo.FONT_WEIGHT_BOLD)
                if sel:
                    cr.set_source_rgb(ar, ag, ab)
                else:
                    cr.set_source_rgba(tr, tg, tb, 1.0 if online else 0.45)
                te = cr.text_extents(num)
                cr.move_to(sx + sw / 2 - te[2] / 2 - te[0],
                           sy + sh / 2 - te[3] / 2 - te[1] - sh * 0.06)
                cr.show_text(num)

                # Name below number
                name_s = monitors[i]["name"]
                cr.set_font_size(min(sw * 0.11, 12))
                cr.select_font_face("monospace", cairo.FONT_SLANT_NORMAL,
                                    cairo.FONT_WEIGHT_NORMAL)
                cr.set_source_rgba(dr, dg, db, 1.0 if online else 0.5)
                te2 = cr.text_extents(name_s)
                cr.move_to(sx + sw / 2 - te2[2] / 2 - te2[0], sy + sh * 0.68)
                cr.show_text(name_s)

                # Resolution@rate bottom
                res_s = f"{monitors[i]['resolution']}@{monitors[i]['rate']:.0f}Hz"
                cr.set_font_size(min(sw * 0.085, 10))
                cr.set_source_rgba(mr, mg, mb, 1.0 if online else 0.4)
                te3 = cr.text_extents(res_s)
                cr.move_to(sx + sw / 2 - te3[2] / 2 - te3[0], sy + sh * 0.86)
                cr.show_text(res_s)

        canvas.connect("draw", _draw)

        def _on_click(widget, event):
            for i, (rx, ry, rw, rh) in enumerate(_rects):
                if rx <= event.x <= rx + rw and ry <= event.y <= ry + rh:
                    _sel[0] = i
                    _update_detail()
                    widget.queue_draw()
                    break

        canvas.connect("button-press-event", _on_click)

        canvas_wrap = Gtk.Frame()
        canvas_wrap.get_style_context().add_class("card")
        canvas_wrap.add(canvas)
        outer.pack_start(canvas_wrap, False, False, 4)

        # ── Detail form ───────────────────────────────────────────────────────
        detail_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=6)
        outer.pack_start(detail_box, False, False, 0)

        def _safe_scales(w, h, lo=0.5, hi=3.0):
            """Scales where w/s and h/s are both integers (no fractional border gap)."""
            from math import gcd
            result = {}
            for q in range(1, 17):
                for p in range(max(1, math.ceil(lo * q)), math.floor(hi * q) + 1):
                    if gcd(p, q) != 1:
                        continue
                    if w * q % p == 0 and h * q % p == 0:
                        s = round(p / q, 6)
                        if s not in result:
                            result[s] = (w * q // p, h * q // p)
            return sorted(result.items())  # [(scale, (lw, lh)), ...]

        # Widgets that persist (only rebuilt when monitor changes)
        res_combo   = Gtk.ComboBoxText(has_entry=True)
        rate_combo  = Gtk.ComboBoxText(has_entry=True)
        scale_combo = Gtk.ComboBoxText(has_entry=True)   # safe scales only
        pos_entry  = Gtk.Entry()
        name_entry = Gtk.Entry()
        transform_combo = Gtk.ComboBoxText()
        _TRANSFORMS = [
            (0, "Normal"),
            (1, "90° CW  (portrait →)"),
            (3, "90° CCW (← portrait)"),
            (2, "180°  (upside down)"),
            (4, "Flipped"),
            (5, "Flipped + 90° CW"),
            (7, "Flipped + 90° CCW"),
            (6, "Flipped + 180°"),
        ]
        _TRANSFORM_VALS = []
        for _tv, _tl in _TRANSFORMS:
            transform_combo.append_text(_tl)
            _TRANSFORM_VALS.append(_tv)
        transform_combo.set_active(0)

        res_combo.set_size_request(170, -1)
        rate_combo.set_size_request(110, -1)
        scale_combo.set_size_request(200, -1)
        pos_entry.set_size_request(120, -1)
        name_entry.set_size_request(120, -1)
        transform_combo.set_size_request(200, -1)
        self._w["_mon_res"]   = res_combo
        self._w["_mon_rate"]  = rate_combo
        self._w["_mon_scale"] = scale_combo
        self._w["_mon_pos"]   = pos_entry

        def _save_detail():
            """Write current form values into monitors[_sel[0]]."""
            if _sel[0] < 0 or _sel[0] >= len(monitors):
                return
            m = monitors[_sel[0]]
            res_text  = (res_combo.get_child().get_text()  if res_combo.get_child()  else "").strip()
            rate_text = (rate_combo.get_child().get_text() if rate_combo.get_child() else "").strip()
            if res_text:  m["resolution"] = res_text
            if rate_text:
                try: m["rate"] = float(rate_text)
                except Exception: pass
            m["pos"]  = pos_entry.get_text().strip()
            m["name"] = name_entry.get_text().strip()
            try:
                sc_raw = (scale_combo.get_child().get_text() if scale_combo.get_child()
                          else str(scale_combo.get_active_text() or "1.0"))
                m["scale"] = float(sc_raw.split()[0])
            except Exception:
                pass
            tidx = transform_combo.get_active()
            if tidx >= 0:
                m["transform"] = _TRANSFORM_VALS[tidx]
            canvas.queue_draw()

        def _on_res_changed(*_):
            """Only repopulates rate dropdown — does NOT write to monitors[]."""
            if _sel[0] < 0 or _sel[0] >= len(monitors):
                return
            res_text = (res_combo.get_child().get_text() if res_combo.get_child() else "").strip()
            modes    = _live_modes.get(monitors[_sel[0]]["name"], [])
            rate_set = sorted({rt for rs, rt in modes if rs == res_text}, reverse=True)
            rate_combo.remove_all()
            for rt in (rate_set or [240.0, 165.0, 144.0, 120.0, 100.0, 75.0, 60.0]):
                rate_combo.append_text(f"{rt:.1f}")
            if rate_set:
                rate_combo.get_child().set_text(f"{rate_set[0]:.1f}")
            _refresh_scale_combo(res_text)

        def _refresh_scale_combo(res_text, current_scale=None):
            """Repopulate scale_combo with safe (integer-logical) scales for res_text."""
            try:
                w, h = (int(x) for x in res_text.lower().split("x"))
            except Exception:
                w, h = 0, 0
            safe = _safe_scales(w, h) if w and h else []
            if not safe:
                safe = [(1.0, (w or 1920, h or 1080)), (1.25, (0, 0)),
                        (1.5, (0, 0)), (2.0, (0, 0))]
            scale_combo.remove_all()
            for s, (lw, lh) in safe:
                lbl = f"{s:.4g}   ({lw}×{lh})" if lw else f"{s:.4g}"
                scale_combo.append_text(lbl)
            # Restore current value if provided
            is_safe = False
            if current_scale is not None:
                matched = next((f"{s:.4g}   ({lw}×{lh})" for s, (lw, lh) in safe
                                if abs(s - current_scale) < 0.001), None)
                if matched:
                    scale_combo.get_child().set_text(matched)
                    is_safe = True
                else:
                    scale_combo.get_child().set_text(str(current_scale))
            _sc_hint.set_markup(
                f'<span foreground="#f38ba8">⚠ Escala {current_scale} no es segura — '
                f'puede aislar monitores. Elige una de la lista.</span>'
                if not is_safe and current_scale is not None else
                '<span foreground="#6c7086">Escalas seguras — resolución lógica entera, sin gaps.</span>'
            )

        # Text fields: save on focus-out (not on every keystroke — avoids mid-switch corruption)
        res_combo.get_child().connect("changed", _on_res_changed)
        res_combo.get_child().connect("focus-out-event",  lambda w, e: _save_detail() or False)
        rate_combo.get_child().connect("focus-out-event", lambda w, e: _save_detail() or False)
        pos_entry.connect("focus-out-event",  lambda w, e: _save_detail() or False)
        name_entry.connect("focus-out-event", lambda w, e: _save_detail() or False)
        # Discrete widgets: save immediately
        scale_combo.get_child().connect("changed", lambda *_: _save_detail())
        transform_combo.connect("changed",  lambda *_: _save_detail())

        # ── Build detail layout ONCE ──────────────────────────────────────────
        no_sel_lbl = _hint("Click a display above to configure it.")
        detail_box.pack_start(no_sel_lbl, False, False, 8)

        idx_lbl = Gtk.Label(); idx_lbl.set_halign(Gtk.Align.START)
        detail_box.pack_start(idx_lbl, False, False, 4)

        det_sep = Gtk.Separator()
        detail_box.pack_start(det_sep, False, False, 2)

        name_row = _row("Connector name", name_entry,
                        tip="Hardware port name: DP-1, HDMI-A-1, eDP-1…\n"
                            "Run 'hyprctl monitors' to see available names.")
        detail_box.pack_start(name_row, False, False, 2)

        rr_row = Gtk.Box(spacing=8)
        rr_row.pack_start(_slbl("Resolution", 120), False, False, 0)
        rr_row.pack_start(res_combo, False, False, 0)
        rr_row.pack_start(_slbl("  Rate Hz", 72), False, False, 0)
        rr_row.pack_start(rate_combo, False, False, 0)
        detail_box.pack_start(rr_row, False, False, 2)

        sc_row = Gtk.Box(spacing=8)
        sc_row.pack_start(_slbl("Scale", 120), False, False, 0)
        sc_row.pack_start(scale_combo, False, False, 0)
        _sc_hint = _hint("Safe scales only — integer logical resolution, no border gaps.")
        sc_wrap = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
        sc_wrap.pack_start(sc_row, False, False, 0)
        sc_wrap.pack_start(_sc_hint, False, False, 0)
        detail_box.pack_start(sc_wrap, False, False, 2)

        pos_row = Gtk.Box(spacing=8)
        pos_row.pack_start(_slbl("Position", 120), False, False, 0)
        pos_row.pack_start(pos_entry, False, False, 0)
        for _lbl_t, _lbl_v in [("Right →", "auto-right"), ("← Left", "auto-left"), ("Primary", "0x0")]:
            _pb = Gtk.Button(label=_lbl_t)
            _pb.get_style_context().add_class("open-btn")
            def _set_pos(_, v=_lbl_v):
                pos_entry.set_text(v)
                _save_detail()
            _pb.connect("clicked", _set_pos)
            pos_row.pack_start(_pb, False, False, 0)
        detail_box.pack_start(pos_row, False, False, 2)

        tr_row = _row("Rotation", transform_combo,
                      tip="Rotate the display output.\n"
                          "Use 90° CW or CCW for portrait/vertical monitors.\n"
                          "The diagram updates to show the new orientation.")
        detail_box.pack_start(tr_row, False, False, 2)

        # Permanent rows (header + form rows) — hide all until a monitor is selected
        _form_rows = [idx_lbl, det_sep, name_row, rr_row, sc_wrap, pos_row, tr_row]

        def _update_detail():
            has_sel = (0 <= _sel[0] < len(monitors))
            no_sel_lbl.set_visible(not has_sel)
            for w in _form_rows:
                w.set_visible(has_sel)
            if not has_sel:
                return
            m = monitors[_sel[0]]
            name = m["name"]
            idx_lbl.set_markup(
                f'<span foreground="{t["acc"]}" weight="bold">'
                f'Display {_sel[0] + 1}</span>'
                f'  <span foreground="{t["dim"]}">{name}</span>'
            )
            # Set plain text/entry fields FIRST — scale_spin and transform_combo fire
            # _save_detail immediately when changed, so all other fields must be ready.
            name_entry.set_text(name)
            pos_entry.set_text(m["pos"])

            modes = _live_modes.get(name, [])
            res_combo.remove_all()
            seen_res = []
            for rs, _ in modes:
                if rs not in seen_res:
                    seen_res.append(rs)
                    res_combo.append_text(rs)
            if not seen_res:
                for fb in ["3840x2160", "2560x1440", "1920x1080", "1280x720"]:
                    res_combo.append_text(fb)
            res_combo.get_child().set_text(m["resolution"])

            rate_combo.remove_all()
            cur_res  = m["resolution"]
            rate_set = sorted({rt for rs, rt in modes if rs == cur_res}, reverse=True)
            for rt in (rate_set or [240.0, 165.0, 144.0, 120.0, 100.0, 75.0, 60.0]):
                rate_combo.append_text(f"{rt:.1f}")
            rate_combo.get_child().set_text(f"{m['rate']:.1f}")

            # Discrete widgets last — their signals fire _save_detail, but all fields ready
            _refresh_scale_combo(m["resolution"], m["scale"])
            cur_tr = m.get("transform", 0)
            tr_idx = _TRANSFORM_VALS.index(cur_tr) if cur_tr in _TRANSFORM_VALS else 0
            transform_combo.set_active(tr_idx)

        # ── Add / Remove ─────────────────────────────────────────────────────
        sep2 = Gtk.Separator()
        sep2.set_margin_top(8)
        outer.pack_start(sep2, False, False, 0)

        btns = Gtk.Box(spacing=8)

        def _add_mon(*_):
            monitors.append({
                "name": "HDMI-A-1", "resolution": "1920x1080",
                "rate": 60.0, "pos": "auto-right", "scale": 1.0,
            })
            _sel[0] = len(monitors) - 1
            _update_detail()
            canvas.queue_draw()

        def _rem_mon(*_):
            if not monitors or _sel[0] < 0:
                return
            m = monitors[_sel[0]]
            dlg = Gtk.MessageDialog(
                parent=self, flags=Gtk.DialogFlags.MODAL,
                message_type=Gtk.MessageType.WARNING,
                buttons=Gtk.ButtonsType.NONE,
                text=f"Remove Display {_sel[0] + 1} ({m['name']})?",
            )
            dlg.format_secondary_text(
                "This only removes it from the config — your monitor stays connected.\n"
                "You can add it back with '+ Add Display'."
            )
            dlg.add_button("Cancel", Gtk.ResponseType.CANCEL)
            dlg.add_button("Remove", Gtk.ResponseType.OK)
            dlg.set_default_response(Gtk.ResponseType.CANCEL)
            resp = dlg.run()
            dlg.destroy()
            if resp != Gtk.ResponseType.OK:
                return
            monitors.pop(_sel[0])
            _sel[0] = max(0, _sel[0] - 1) if monitors else -1
            _update_detail()
            canvas.queue_draw()

        add_m = Gtk.Button(label="+ Add Display")
        add_m.get_style_context().add_class("open-btn")
        add_m.connect("clicked", _add_mon)
        rem_m = Gtk.Button(label="- Remove")
        rem_m.get_style_context().add_class("open-btn")
        rem_m.connect("clicked", _rem_mon)
        btns.pack_start(add_m, False, False, 0)
        btns.pack_start(rem_m, False, False, 0)
        outer.pack_start(btns, False, False, 0)

        _update_detail()
        return outer

