        def _fetch_manifest():
            """Fetch manifest from GitHub in background, save cache, reload tab only if changed."""
            try:
                req = urllib.request.Request(
                    _MANIFEST_URL,
                    headers={"User-Agent": "vsHyprland-Manager/" + __version__}
                )
                with urllib.request.urlopen(req, timeout=5) as r:
                    data = r.read().decode()
                remote = _json.loads(data)
                # Compare with current cache to avoid reload loop
                current = _load_tools()
                if remote == current:
                    return  # nothing changed, no rebuild needed
                # Data changed — save cache and refresh UI
                os.makedirs(os.path.dirname(_CACHE_PATH), exist_ok=True)
                with open(_CACHE_PATH, "w") as f:
                    _json.dump(remote, f, indent=2)
                GLib.idle_add(self._reload_hub_tab)
            except Exception:
                pass  # no internet or repo not ready yet — silently use cache/fallback

