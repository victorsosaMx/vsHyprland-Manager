        def _make_thumb_widget(fpath):
            pb_box = [None]     # filled by background thread
            da = Gtk.DrawingArea()
            da.set_size_request(THUMB_W, THUMB_H)
            da.get_style_context().add_class("plugin-card")

            def _draw_thumb(widget, cr, fp=fpath):
                w = widget.get_allocated_width()
                h = widget.get_allocated_height()
                p = pb_box[0]
                if p:
                    scale = max(w / p.get_width(), h / p.get_height())
                    sw2 = int(p.get_width() * scale)
                    sh2 = int(p.get_height() * scale)
                    scaled = p.scale_simple(sw2, sh2, GdkPixbuf.InterpType.BILINEAR)
                    Gdk.cairo_set_source_pixbuf(cr, scaled,
                                                (w - sw2) // 2, (h - sh2) // 2)
                    cr.paint()
                    if fp == _current_path[0]:
                        cr.set_source_rgba(0.67, 0.82, 0.56, 0.3)
                        cr.rectangle(0, 0, w, h)
                        cr.fill()
                        cr.set_source_rgba(0.67, 0.82, 0.56, 0.9)
                        cr.set_line_width(2.5)
                        cr.rectangle(1, 1, w - 2, h - 2)
                        cr.stroke()
                else:
                    cr.set_source_rgb(0.15, 0.17, 0.13)
                    cr.rectangle(0, 0, w, h)
                    cr.fill()

            da.connect("draw", _draw_thumb)
            ev = Gtk.EventBox()
            ev.add(da)

            def _on_click(widget, event, fp=fpath):
                if event.button == 1:
                    _set_wallpaper(fp)
                    flow.queue_draw()

            ev.connect("button-press-event", _on_click)
            ev.set_tooltip_text(os.path.basename(fpath))

            def _load_thumb_bg(fp=fpath):
                pb = _load_pixbuf(fp, THUMB_W * 2, THUMB_H * 2)
                def _set(_):
                    pb_box[0] = pb
                    da.queue_draw()
                    return False
                GLib.idle_add(_set, None)

            threading.Thread(target=_load_thumb_bg, daemon=True).start()
            return ev

