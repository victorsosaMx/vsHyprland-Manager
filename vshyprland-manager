    def _status(self, msg):
        if self._status_timer:
            GLib.source_remove(self._status_timer)
        if self._status_lbl:
            self._status_lbl.set_text(msg)
        self._status_timer = GLib.timeout_add(4000, self._clear_status)

    def _clear_status(self):
