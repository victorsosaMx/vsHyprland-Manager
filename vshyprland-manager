        def _default_content(path):
            return self._SCRIPT_DEFAULTS.get(path, f"#!/bin/bash\n# {os.path.expanduser(path)}\n")

        def _load_script(path):
            p = os.path.expanduser(path)
            try:
                return open(p).read()
            except Exception:
