            "xtra-dispatchers":         "Extra keybind dispatchers",
            "hyprgrass":                "Touch/touchpad gesture bindings",
            "csgo-vulkan-fix":          "Fix for CS:GO Vulkan rendering",
        }

        # ── Parse hyprpm list ─────────────────────────────────────────────────
        _repos    = []   # [(repo_name, author)]
        _enabled  = set()
        _all      = []   # [name, ...]

        try:
            raw = subprocess.check_output(
                ["hyprpm", "list"], text=True, stderr=subprocess.STDOUT
            )
            # Strip ANSI escape codes (hyprpm uses colors: \x1b[32mtrue, \x1b[31mfalse)
            raw = re.sub(r'\x1b\[[0-9;]*[mGKHFABCDJ]', '', raw)
            cur = None
            for line in raw.splitlines():
                repo_m = re.search(r'Repository\s+(\S+)\s+\(by\s+([^)]+)\)', line)
                if repo_m:
                    _repos.append((repo_m.group(1), repo_m.group(2).strip()))
                plug_m = re.search(r'Plugin\s+([\w\-]+)', line)
                if plug_m:
                    cur = plug_m.group(1)
                if cur and re.search(r'failed to build', line, re.IGNORECASE):
                    cur = None  # skip broken plugins entirely
                    continue
                if cur and plug_m:
                    _all.append(cur)
                if cur and re.search(r'enabled\s*:\s*true', line, re.IGNORECASE):
                    _enabled.add(cur)
        except Exception:
