def parse_binds(text):
    variables = {}
    for m in re.finditer(r'^\s*\$(\w+)\s*=\s*(.+)$', text, re.MULTILINE):
        variables[f"${m.group(1)}"] = m.group(2).strip()
    binds = []
    for m in re.finditer(
        r'^\s*(bind[elmd]*)\s*=\s*([^,]*),\s*([^,]+),\s*([^,\n]+)(?:,\s*(.+))?$',
        text, re.MULTILINE
    ):
        binds.append({
            "type":       m.group(1).strip(),
            "mods":       m.group(2).strip(),
            "key":        m.group(3).strip(),
            "dispatcher": m.group(4).strip(),
            "params":     (m.group(5) or "").strip(),
        })
    return {"variables": variables, "binds": binds}

def parse_rules(text):
    wrs = []
    for m in re.finditer(r'windowrule\s*\{([^{}]*)\}', text, re.DOTALL):
        block = m.group(1)
        wr = {}
        for key in ("name", "match:class", "match:title", "float", "center",
                    "size", "move", "pin", "opacity", "suppress_event"):
            v = _parse_scalar(block, key, None)
            if v is not None:
                wr[key] = v
        if wr:
            wrs.append(wr)
    lrs = []
    for m in re.finditer(r'^\s*layerrule\s*=\s*([^,\n]+),\s*(.+)$', text, re.MULTILINE):
        lrs.append({"rule": m.group(1).strip(), "namespace": m.group(2).strip()})
    blurls = [b.strip() for b in re.findall(r'^\s*blurls\s*=\s*(.+)$', text, re.MULTILINE)]
    return {"windowrules": wrs, "layerrules": lrs, "blurls": blurls}

def parse_autostart(text):
    result = []
    for m in re.finditer(r'^(\s*#?\s*)exec-once\s*=\s*(.+)$', text, re.MULTILINE):
        enabled = '#' not in m.group(1)
        full = m.group(2).strip()
        # Name stored as trailing "  # Label" (two spaces before #)
        if '  # ' in full:
            cmd, name = full.rsplit('  # ', 1)
        else:
            cmd, name = full, ""
        result.append({"enabled": enabled, "cmd": cmd.strip(), "name": name.strip()})
    return result

def parse_env(text):
    return [
        (m.group(1).strip(), m.group(2).strip())
        for m in re.finditer(r'^\s*env\s*=\s*([^,\n]+),\s*(.+)$', text, re.MULTILINE)
    ]

def parse_monitors(text):
    mons = []
    for m in re.finditer(
        r'^\s*monitor\s*=\s*([^,]+),\s*([^,]+),\s*([^,]+),\s*([\d.]+)'
        r'(?:,\s*transform\s*,\s*(\d+))?',
        text, re.MULTILINE
    ):
        res_rate = m.group(2).strip()
        rm = re.match(r'(\d+x\d+)@([\d.]+)', res_rate)
        res  = rm.group(1) if rm else res_rate
        rate = float(rm.group(2)) if rm else 60.0
        mons.append({
            "name":       m.group(1).strip(),
            "resolution": res,
            "rate":       rate,
            "pos":        m.group(3).strip(),
            "scale":      float(m.group(4).strip()),
            "transform":  int(m.group(5)) if m.group(5) else 0,
        })
    return mons

