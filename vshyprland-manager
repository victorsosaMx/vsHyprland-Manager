        prof_lbl.set_halign(Gtk.Align.START)

        prof_combo = Gtk.ComboBoxText(has_entry=True)
        prof_combo.set_size_request(220, -1)
        _refresh_combo()

        def _current_profile_name():
            entry = prof_combo.get_child()
            return entry.get_text().strip() if entry else ""

        def _collect_profile():
            """Snapshot current store state into a profile dict."""
            variables = {r[0]: r[1] for r in var_store if r[0]}
            binds = [
                {"type": r[0], "mods": r[1], "key": r[2],
                 "dispatcher": r[3], "params": r[4]}
                for r in bind_store
            ]
            return {"variables": variables, "binds": binds}

        def _apply_data(data):
            """Populate var_store and bind_store from a profile dict."""
            var_store.clear()
            for k, v in data.get("variables", {}).items():
                var_store.append([k, v])
            bind_store.clear()
            for b in data.get("binds", []):
                bind_store.append([
                    b.get("type", "bind"), b.get("mods", ""), b.get("key", ""),
                    b.get("dispatcher", ""), b.get("params", "")
                ])

        # Snapshot loaded from disk — restored by Default button
        _initial_snapshot = [{
            "variables": dict(self._cfg.get("variables", {})),
            "binds":     [dict(b) for b in self._cfg.get("binds", [])],
        }]

        def _save_profile(*_):
            name = _current_profile_name()
            if not name or name.startswith(_PRESET_PREFIX):
                return
            path = os.path.join(PROF_DIR, name + ".json")
            with open(path, "w") as f:
                _json.dump(_collect_profile(), f, indent=2, ensure_ascii=False)
            _refresh_combo(select=name)

        def _load_profile(*_):
            name = _current_profile_name()
            if not name:
                return
            # Built-in preset?
            preset_key = name[len(_PRESET_PREFIX):] if name.startswith(_PRESET_PREFIX) else None
            if preset_key and preset_key in _KB_PRESETS:
                _apply_data(_KB_PRESETS[preset_key])
                return
            path = os.path.join(PROF_DIR, name + ".json")
            if not os.path.exists(path):
                return
            with open(path) as f:
                _apply_data(_json.load(f))

        def _delete_profile(*_):
            name = _current_profile_name()
            if not name or name.startswith(_PRESET_PREFIX):
                return
            path = os.path.join(PROF_DIR, name + ".json")
            if not os.path.exists(path):
                return
            dlg = Gtk.MessageDialog(
                transient_for=self, modal=True,
                message_type=Gtk.MessageType.QUESTION,
                buttons=Gtk.ButtonsType.YES_NO,
                text=f'Delete profile "{name}"?',
            )
            if dlg.run() == Gtk.ResponseType.YES:
                os.remove(path)
                _refresh_combo()
            dlg.destroy()

        def _restore_default(*_):
            _apply_data(_initial_snapshot[0])

        btn_save    = Gtk.Button(label="Save")
        btn_load    = Gtk.Button(label="Load")
        btn_del     = Gtk.Button(label="Delete")
        btn_default = Gtk.Button(label="Default")
        for b in (btn_save, btn_load, btn_del, btn_default):
            b.get_style_context().add_class("open-btn")
        btn_save.connect("clicked",    _save_profile)
        btn_load.connect("clicked",    _load_profile)
        btn_del.connect("clicked",     _delete_profile)
        btn_default.connect("clicked", _restore_default)
        btn_default.set_tooltip_text("Restore bindings to the state loaded from disk")

        prof_row.pack_start(prof_lbl,     False, False, 0)
        prof_row.pack_start(prof_combo,   False, False, 0)
        prof_row.pack_start(btn_save,     False, False, 0)
        prof_row.pack_start(btn_load,     False, False, 0)
        prof_row.pack_start(btn_del,      False, False, 0)
        prof_row.pack_start(btn_default,  False, False, 8)
        bt.pack_start(prof_row, False, False, 4)

        # ── Search ────────────────────────────────────────────────────────────
        search = Gtk.Entry()
        search.set_placeholder_text("Search binding...")
        bt.pack_start(search, False, False, 4)

        bind_store = Gtk.ListStore(str, str, str, str, str)
        for b in self._cfg.get("binds", []):
            bind_store.append([b["type"], b["mods"], b["key"], b["dispatcher"], b["params"]])
        self._w["bind_store"] = bind_store

        filter_model = bind_store.filter_new()
        search_text = [""]

        def match_func(model, it, data):
            q = search_text[0].lower()
            if not q:
                return True
            return any(q in str(model[it][i]).lower() for i in range(5))

        filter_model.set_visible_func(match_func)

        def on_search(e):
            search_text[0] = e.get_text()
            filter_model.refilter()

        search.connect("changed", on_search)

        bind_tv = Gtk.TreeView(model=filter_model)

        # Type column with combo
        type_store = Gtk.ListStore(str)
        for t in ["bind", "binde", "bindl", "bindel", "bindm"]:
            type_store.append([t])
        r_type = Gtk.CellRendererCombo(
            model=type_store, text_column=0, editable=True, has_entry=False
        )

        def on_type_changed(cell, path_str, new_it):
            try:
                fpath = Gtk.TreePath.new_from_string(path_str)
                child_it = filter_model.convert_iter_to_child_iter(
                    filter_model.get_iter(fpath)
                )
                if child_it:
                    bind_store[child_it][0] = type_store[new_it][0]
            except Exception:
                pass

        r_type.connect("changed", on_type_changed)
        col_type = Gtk.TreeViewColumn("Type", r_type, text=0)
        col_type.set_min_width(70)
        bind_tv.append_column(col_type)

        bind_col_specs = [
            ("Mods", 130), ("Key", 80), ("Dispatcher", 150), ("Params", 200)
        ]
        for i, (title, w_) in enumerate(bind_col_specs, 1):
            r = Gtk.CellRendererText(editable=True)
            col_idx = i

            def on_bind_edit(cell, path_str, text, col=col_idx):
                try:
                    fpath = Gtk.TreePath.new_from_string(path_str)
                    child_it = filter_model.convert_iter_to_child_iter(
                        filter_model.get_iter(fpath)
                    )
                    if child_it:
                        bind_store[child_it][col] = text
                except Exception:
                    pass

            r.connect("edited", on_bind_edit)
            col = Gtk.TreeViewColumn(title, r, text=i)
            col.set_min_width(w_)
            bind_tv.append_column(col)

        bind_sw = Gtk.ScrolledWindow()
        bind_sw.set_policy(Gtk.PolicyType.AUTOMATIC, Gtk.PolicyType.AUTOMATIC)
        bind_sw.set_min_content_height(300)
        bind_sw.add(bind_tv)
        bt.pack_start(bind_sw, True, True, 0)

        bind_btns = Gtk.Box(spacing=8)
        add_bi = Gtk.Button(label="+ Add")
        add_bi.get_style_context().add_class("open-btn")
        rem_bi = Gtk.Button(label="- Remove")
        rem_bi.get_style_context().add_class("open-btn")

        def add_bind(*_):
            bind_store.append(["bind", "$mod", "Q", "killactive", ""])

        def rem_bind(*_):
            sel = bind_tv.get_selection()
            model, it = sel.get_selected()
            if it:
                try:
                    child_it = filter_model.convert_iter_to_child_iter(it)
                    bind_store.remove(child_it)
                except Exception:
                    pass

        add_bi.connect("clicked", add_bind)
        rem_bi.connect("clicked", rem_bind)
        bind_btns.pack_start(add_bi, False, False, 0)
        bind_btns.pack_start(rem_bi, False, False, 0)
        bt.pack_start(bind_btns, False, False, 0)

        outer.pack_start(kb_nb, False, False, 0)
        return outer

