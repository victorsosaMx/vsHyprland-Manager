    def _run_in_terminal(self, cmds, on_done=None):
        script = " && ".join(cmds) + "; echo; echo 'Listo — presiona Enter para cerrar'; read"
        try:
            proc = subprocess.Popen(["kitty", "-e", "bash", "-c", script])
            if on_done:
                def _wait():
                    proc.wait()
                    GLib.idle_add(on_done)
                threading.Thread(target=_wait, daemon=True).start()
        except Exception:
            pass

