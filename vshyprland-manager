    def _ensure_original_backup(self):
        """Copy current config to backups/original — only on first ever Apply."""
        if os.path.isdir(_BACKUP_ORIGINAL):
            return  # Already preserved — never touch again
        os.makedirs(_BACKUP_ORIGINAL, exist_ok=True)
        copied = []
        for path in [_F_APP, _F_ANIM, _F_INP, _F_BINDS, _F_RULES,
                     _F_AUTO, _F_ENV, _F_PLUG, _F_MON, _F_MAIN]:
            if os.path.isfile(path):
                dst = os.path.join(_BACKUP_ORIGINAL, os.path.basename(path))
                shutil.copy2(path, dst)
                copied.append(os.path.basename(path))
        # Write a README so the user knows what this folder is
        readme = (
            "# Original Config Backup\n"
            f"# Preserved by vshyprland on first Apply — {datetime.datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\n"
            "# This folder is NEVER modified by the app.\n"
            "# To restore: copy these files back to ~/.config/hypr/\n\n"
            f"fresh_install: {'yes' if not copied else 'no'}\n"
            f"Files: {', '.join(copied) if copied else 'none — fresh install, vshyprland created everything'}\n"
        )
        with open(os.path.join(_BACKUP_ORIGINAL, "README.md"), "w") as f:
            f.write(readme)

    def _restore_original_backup(self):
        """Restore all files from backups/original and reload Hyprland."""
        if not os.path.isdir(_BACKUP_ORIGINAL):
            return False
        for fn in os.listdir(_BACKUP_ORIGINAL):
            if fn == "README.md": continue
            src = os.path.join(_BACKUP_ORIGINAL, fn)
            # Map filename back to correct path
            for path in [_F_APP, _F_ANIM, _F_INP, _F_BINDS, _F_RULES,
                         _F_AUTO, _F_ENV, _F_PLUG, _F_MON, _F_MAIN]:
                if os.path.basename(path) == fn:
                    shutil.copy2(src, path)
                    break
        if bool(os.environ.get("HYPRLAND_INSTANCE_SIGNATURE")):
            subprocess.run(["hyprctl", "reload"], timeout=5,
                           stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        return True

    def _backup_configs(self):
        ts = datetime.datetime.now().strftime("%Y%m%d_%H%M%S")
        os.makedirs(_BACKUP, exist_ok=True)
        for path in [_F_APP, _F_ANIM, _F_INP, _F_BINDS, _F_RULES,
                     _F_AUTO, _F_ENV, _F_PLUG, _F_MON]:
            if os.path.isfile(path):
                dst = os.path.join(_BACKUP, f"{ts}_{os.path.basename(path)}")
                shutil.copy2(path, dst)
        return ts

    def _revert_to_backup(self, ts):
        """Restore all config files from a given backup timestamp."""
        for path in [_F_APP, _F_ANIM, _F_INP, _F_BINDS, _F_RULES,
                     _F_AUTO, _F_ENV, _F_PLUG, _F_MON]:
            src = os.path.join(_BACKUP, f"{ts}_{os.path.basename(path)}")
            if os.path.isfile(src):
                shutil.copy2(src, path)
        if bool(os.environ.get("HYPRLAND_INSTANCE_SIGNATURE")):
            subprocess.run(["hyprctl", "reload"], timeout=5,
                           stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)

    def _show_revert_dialog(self, ts, seconds=10):
        """Countdown dialog — revert automatically if user doesn't confirm."""
        # Close any previous revert dialog (treat as "keep") before showing new one
        if hasattr(self, "_active_revert_dlg") and self._active_revert_dlg:
            try:
                self._active_revert_dlg._keep_fn()
            except Exception:
                pass

        dlg = Gtk.Window(title="Apply settings?")
        dlg.set_transient_for(self)
        dlg.set_modal(True)
        dlg.set_resizable(False)
        dlg.set_default_size(380, 1)
        dlg.set_type_hint(Gdk.WindowTypeHint.DIALOG)

        t = self._theme
        outer = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        outer.get_style_context().add_class("plugin-card")

        # Header
        hdr = Gtk.Box(spacing=10)
        hdr.set_margin_start(20); hdr.set_margin_end(20)
        hdr.set_margin_top(18);   hdr.set_margin_bottom(6)
        icon = Gtk.Label()
        icon.set_markup(f'<span font_desc="JetBrainsMono Nerd Font 22" foreground="{t["acc"]}">󰋔</span>')
        title = Gtk.Label()
        title.set_markup(f'<b>Keep these settings?</b>')
        title.set_halign(Gtk.Align.START)
        hdr.pack_start(icon,  False, False, 0)
        hdr.pack_start(title, False, False, 0)
        outer.pack_start(hdr, False, False, 0)

        # Countdown label
        count_lbl = Gtk.Label()
        count_lbl.set_markup(
            f'<span foreground="{t["dim"]}">Reverting to previous config in <b>{seconds}</b>s…</span>')
        count_lbl.set_margin_start(20); count_lbl.set_margin_end(20)
        count_lbl.set_margin_bottom(10)
        count_lbl.set_halign(Gtk.Align.START)
        outer.pack_start(count_lbl, False, False, 0)

        # Progress bar
        bar = Gtk.ProgressBar()
        bar.set_fraction(1.0)
        bar.set_margin_start(20); bar.set_margin_end(20)
        bar.set_margin_bottom(16)
        outer.pack_start(bar, False, False, 0)

        # Buttons
        btn_row = Gtk.Box(spacing=10)
        btn_row.set_margin_start(20); btn_row.set_margin_end(20)
        btn_row.set_margin_bottom(18)
        btn_row.set_halign(Gtk.Align.END)

        revert_btn = Gtk.Button(label="↩  Revert now")
        revert_btn.get_style_context().add_class("open-btn")

        keep_btn = Gtk.Button(label="  Keep changes")
        keep_btn.get_style_context().add_class("save-btn")

        btn_row.pack_start(revert_btn, False, False, 0)
        btn_row.pack_start(keep_btn,  False, False, 0)
        outer.pack_start(btn_row, False, False, 0)

        dlg.add(outer)

        _remaining = [seconds]
        _timer_id  = [None]
        _resolved  = [False]

        def _close_keep(*_):
            if _resolved[0]: return
            _resolved[0] = True
            if _timer_id[0]: GLib.source_remove(_timer_id[0])
            self._status("Settings kept")
            dlg.destroy()

        def _close_revert(*_):
            if _resolved[0]: return
            _resolved[0] = True
            if _timer_id[0]: GLib.source_remove(_timer_id[0])
            dlg.destroy()
            self._revert_to_backup(ts)
            self._status("Config reverted to previous backup")

        def _tick():
            if _resolved[0]: return False
            _remaining[0] -= 1
            frac = _remaining[0] / seconds
            bar.set_fraction(max(frac, 0))
            if _remaining[0] <= 0:
                count_lbl.set_markup(
                    f'<span foreground="{t["dim"]}">Reverting…</span>')
                _close_revert()
                return False
            count_lbl.set_markup(
                f'<span foreground="{t["dim"]}">Reverting to previous config in <b>{_remaining[0]}</b>s…</span>')
            return True

        keep_btn.connect("clicked",   _close_keep)
        revert_btn.connect("clicked", _close_revert)
        dlg.connect("delete-event",   lambda *_: _close_revert() or True)

        # Register so a subsequent Apply can close this dialog cleanly
        dlg._keep_fn = _close_keep
        self._active_revert_dlg = dlg

        def _on_destroy(*_):
            if getattr(self, "_active_revert_dlg", None) is dlg:
                self._active_revert_dlg = None

        dlg.connect("destroy", _on_destroy)

        dlg.show_all()
        _timer_id[0] = GLib.timeout_add(1000, _tick)

    def _write_main_conf(self):
        """Create hyprland.conf with source lines if it doesn't exist."""
        if os.path.isfile(_F_MAIN):
            # Add any missing source lines without touching existing content
            try:
                existing = open(_F_MAIN).read()
            except Exception:
                existing = ""
            needed = [
                (_F_MON,   f"source = {_F_MON}"),
                (_F_APP,   f"source = {_F_APP}"),
                (_F_ANIM,  f"source = {_F_ANIM}"),
                (_F_INP,   f"source = {_F_INP}"),
                (_F_BINDS, f"source = {_F_BINDS}"),
                (_F_RULES, f"source = {_F_RULES}"),
                (_F_AUTO,  f"source = {_F_AUTO}"),
                (_F_ENV,   f"source = {_F_ENV}"),
                (_F_PLUG,  f"source = {_F_PLUG}"),
            ]
            additions = [line for _, line in needed if os.path.basename(_) not in existing]
            if additions:
                with open(_F_MAIN, "a") as f:
                    f.write("\n# Added by vshyprland\n")
                    f.write("\n".join(additions) + "\n")
        else:
            os.makedirs(_HYPR, exist_ok=True)
            lines = [
                "# Generated by vshyprland",
                "# Main Hyprland config — sources all module files",
                "",
                f"source = {_F_MON}",
                f"source = {_F_APP}",
                f"source = {_F_ANIM}",
                f"source = {_F_INP}",
                f"source = {_F_BINDS}",
                f"source = {_F_RULES}",
                f"source = {_F_AUTO}",
                f"source = {_F_ENV}",
                f"source = {_F_PLUG}",
                "",
            ]
            with open(_F_MAIN, "w") as f:
                f.write("\n".join(lines))

    def _on_apply(self, *_):
        self._collect()
        # Preserve original config exactly once — never overwritten
        self._ensure_original_backup()
        backup_ts = self._backup_configs()
        self._write_main_conf()
        hyprland_running = bool(os.environ.get("HYPRLAND_INSTANCE_SIGNATURE"))
        try:
            def read(p):
                try:
                    return open(p).read()
                except Exception:
                    return ""

            os.makedirs(_MODS, exist_ok=True)
            with open(_F_APP,   "w") as f:
                f.write(build_appearance(self._cfg, read(_F_APP)))
            with open(_F_ANIM,  "w") as f:
                f.write(build_animations(self._cfg, read(_F_ANIM)))
            with open(_F_INP,   "w") as f:
                f.write(build_input(self._cfg, read(_F_INP)))
            with open(_F_BINDS, "w") as f:
                f.write(build_binds(self._cfg, read(_F_BINDS)))
            with open(_F_RULES, "w") as f:
                f.write(build_rules(self._cfg, read(_F_RULES)))
            with open(_F_AUTO,  "w") as f:
                f.write(build_autostart(self._cfg, read(_F_AUTO)))
            with open(_F_ENV,   "w") as f:
                f.write(build_env(self._cfg, read(_F_ENV)))
            with open(_F_PLUG,  "w") as f:
                f.write(build_plugins(self._cfg, read(_F_PLUG)))
            with open(_F_MON,   "w") as f:
                f.write(build_monitors(self._cfg))
            # Hot corners script — use live monitors when available
            try:
                _raw = subprocess.check_output(
                    ["hyprctl", "monitors", "-j"], text=True, stderr=subprocess.DEVNULL)
                hc_monitors = [{"name": m["name"]} for m in _json.loads(_raw)]
            except Exception:
                hc_monitors = self._cfg.get("monitors") or [{"name": ""}]
            hc_script = build_hotcorners(self._cfg, hc_monitors)
            subprocess.run(["pkill", "-f", "hotcorner.sh"], check=False)
            if hc_script is not None:
                with open(_F_HOT, "w") as f:
                    f.write(hc_script)
                os.chmod(_F_HOT, 0o755)
                # Ensure hotcorner.sh is in autostart for persistence across reboots
                auto = self._cfg.setdefault("autostart", [])
                if not any(_F_HOT in e.get("cmd", "") for e in auto):
                    auto.append({"enabled": True, "cmd": _F_HOT, "name": "Hot Corners"})
                    with open(_F_AUTO, "w") as f:
                        f.write(build_autostart(self._cfg, read(_F_AUTO)))
                if hyprland_running:
                    subprocess.Popen(["/bin/bash", _F_HOT])
            else:
                # Disabled — remove from autostart
                auto = self._cfg.get("autostart", [])
                before = len(auto)
                self._cfg["autostart"] = [e for e in auto if _F_HOT not in e.get("cmd", "")]
                if len(self._cfg["autostart"]) != before:
                    with open(_F_AUTO, "w") as f:
                        f.write(build_autostart(self._cfg, read(_F_AUTO)))
        except Exception as e:
            self._err(f"Error saving:\n{e}")
            return
        if hyprland_running:
            try:
                subprocess.run(
                    ["hyprctl", "reload"], timeout=5,
                    stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL
                )
                self._status("Config saved — hyprctl reload executed")
            except Exception as e:
                self._status(f"Config saved — hyprctl error: {e}")
        else:
            self._status("Config saved — start Hyprland to apply")

        # Apply wallpaper if the widget exists and has a path
        if "_apply_wp" in self._w:
            self._w["_apply_wp"]()

    def _refresh_preview(self, *_):
