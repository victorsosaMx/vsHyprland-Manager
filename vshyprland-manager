    for k, v in cfg["env"]:
        lines.append(f"env = {k},{v}")
    return "\n".join(lines) + "\n"

def build_monitors(cfg):
    lines = ["# Generated by vsHyprland-Manager", ""]
    mons = [dict(m) for m in cfg["monitors"]]

    def _logical_w(m):
        try:
            w = int(m["resolution"].split("@")[0].split("x")[0])
            return math.ceil(w / float(m.get("scale", 1.0)))
        except Exception:
            return 1920

    def _parse_xy(pos):
        try:
            x, y = pos.lower().split("x")
            return int(x), int(y)
        except Exception:
            return None

    # If all monitors use numeric positions, recalculate X so they stay
    # adjacent after a scale change (logical width changes with scale).
    parsed = [_parse_xy(m.get("pos", "0x0")) for m in mons]
    if all(p is not None for p in parsed):
        order = sorted(range(len(mons)), key=lambda i: parsed[i][0])
        cur_x = 0
        for i in order:
            _, y = parsed[i]
            mons[i]["pos"] = f"{cur_x}x{y}"
            cur_x += _logical_w(mons[i])

    for m in mons:
        rate = m.get("rate", 0)
        res_part = m["resolution"] if not rate else f"{m['resolution']}@{rate}"
        scale = int(m["scale"]) if m["scale"] == int(m["scale"]) else m["scale"]
        base = f"monitor={m['name']},{res_part},{m['pos']},{scale}"
        if m.get("transform", 0):
            base += f",transform,{m['transform']}"
        lines.append(base)
    return "\n".join(lines) + "\n"

