            def _comment_plugin_binds(plugin_name):
                """Comment out bindings that use this plugin's dispatcher in binds.conf."""
                prefix = _PLUGIN_DISPATCHERS.get(plugin_name)
                if not prefix:
                    return
                try:
                    with open(_F_BINDS, "r") as f:
                        lines = f.readlines()
                    changed = False
                    new_lines = []
                    for line in lines:
                        stripped = line.lstrip()
                        # Active bind using this plugin's dispatcher
                        if (not stripped.startswith("#") and
                                re.search(r'\b' + re.escape(prefix), line)):
                            new_lines.append("# " + line)
                            changed = True
                        else:
                            new_lines.append(line)
                    if changed:
                        with open(_F_BINDS, "w") as f:
                            f.writelines(new_lines)
                except Exception:
                    pass

            def _uncomment_plugin_binds(plugin_name):
                """Re-enable bindings for this plugin's dispatcher."""
                prefix = _PLUGIN_DISPATCHERS.get(plugin_name)
                if not prefix:
                    return
                try:
                    with open(_F_BINDS, "r") as f:
                        lines = f.readlines()
                    changed = False
                    new_lines = []
                    for line in lines:
                        stripped = line.lstrip()
                        if (stripped.startswith("#") and
                                re.search(r'\b' + re.escape(prefix), line)):
                            # Remove leading "# "
                            new_lines.append(re.sub(r'^(\s*)#\s?', r'\1', line, count=1))
                            changed = True
                        else:
                            new_lines.append(line)
                    if changed:
                        with open(_F_BINDS, "w") as f:
                            f.writelines(new_lines)
                except Exception:
                    pass

