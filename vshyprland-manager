def _default_binds():
    b = []
    def _b(mods, key, disp, params=""):
        return {"type": "bind", "mods": mods, "key": key, "dispatcher": disp, "params": params}
    def _bm(mods, key, disp):
        return {"type": "bindm", "mods": mods, "key": key, "dispatcher": disp, "params": ""}
    M = "$mainMod"
    b += [
        _b(M,           "Return", "exec",            "kitty"),
        _b(M,           "E",      "exec",            "nautilus"),
        _b(M,           "R",      "exec",            "rofi -show drun"),
        _b(M,           "Q",      "killactive"),
        _b(M + " SHIFT","M",      "exit"),
        _b(M,           "V",      "togglefloating"),
        _b(M,           "F",      "fullscreen"),
        _b(M,           "P",      "pseudo"),
        _b(M,           "J",      "togglesplit"),
        _b(M,           "left",   "movefocus",       "l"),
        _b(M,           "right",  "movefocus",       "r"),
        _b(M,           "up",     "movefocus",       "u"),
        _b(M,           "down",   "movefocus",       "d"),
    ]
    for i in range(1, 11):
        key = str(i % 10)
        b.append(_b(M,           key, "workspace",      str(i)))
        b.append(_b(M + " SHIFT",key, "movetoworkspace",str(i)))
    b += [
        _bm(M, "mouse:272", "movewindow"),
        _bm(M, "mouse:273", "resizewindow"),
    ]
    return b

