    def _draw_preview(self, widget, cr):
        w = widget.get_allocated_width()
        h = widget.get_allocated_height()
        t = self._theme

        # Background
        r, g, b = [int(t["hdr"].lstrip("#")[i:i+2], 16)/255 for i in (0, 2, 4)]
        cr.set_source_rgb(r, g, b)
        cr.paint()

        rounding   = self._cfg.get("decoration.rounding", 10)
        bsize      = max(1, self._cfg.get("general.border_size", 2))
        act_border = self._cfg.get("general.col.active_border",   "rgba(89b4faff)")
        inact_bdr  = self._cfg.get("general.col.inactive_border", "rgba(313244aa)")
        inact_op   = self._cfg.get("decoration.inactive_opacity", 0.95)
        shadow_on  = self._cfg.get("shadow.enabled",  True)
        shadow_rng = self._cfg.get("shadow.range",    15)
        shadow_col = self._cfg.get("shadow.color",    "rgba(1a1a2ecc)")

        pad    = 24
        win_h  = h - pad * 2
        win_w  = int((w - pad * 3) * 0.55)
        win2_w = int((w - pad * 3) * 0.4)
        x1, x2 = pad, pad + win_w + pad
        y = pad

        def draw_rounded_rect(cr, x, y, ww, hh, rad):
            rad = min(rad, ww / 2, hh / 2)
            cr.new_path()
            cr.arc(x + rad,      y + rad,      rad, math.pi,    3 * math.pi / 2)
            cr.arc(x + ww - rad, y + rad,      rad, -math.pi/2, 0)
            cr.arc(x + ww - rad, y + hh - rad, rad, 0,           math.pi / 2)
            cr.arc(x + rad,      y + hh - rad, rad, math.pi / 2, math.pi)
            cr.close_path()

        def draw_shadow(cr, x, y, ww, hh, rr, sc):
            sr, sg, sb, sa = _parse_hypr_color(sc)
            steps = min(shadow_rng, 12)
            for i in range(steps, 0, -1):
                alpha = sa * (i / steps) * 0.4
                cr.set_source_rgba(sr, sg, sb, alpha)
                spread = (steps - i + 1) * (shadow_rng / steps)
                draw_rounded_rect(cr, x - spread, y - spread,
                                   ww + spread * 2, hh + spread * 2, rr + spread)
                cr.fill()

        # Active window
        if shadow_on:
            draw_shadow(cr, x1, y, win_w, win_h, rounding, shadow_col)
        cr.set_source_rgba(0.12, 0.12, 0.16, 0.95)
        draw_rounded_rect(cr, x1, y, win_w, win_h, rounding)
        cr.fill()
        br, bg_, bb, ba = _parse_hypr_color(act_border)
        cr.set_source_rgba(br, bg_, bb, ba)
        cr.set_line_width(bsize)
        draw_rounded_rect(cr, x1 + bsize/2, y + bsize/2,
                           win_w - bsize, win_h - bsize, rounding)
        cr.stroke()
        cr.set_source_rgba(0.7, 0.8, 0.7, 0.6)
        cr.select_font_face("monospace", cairo.FONT_SLANT_NORMAL, cairo.FONT_WEIGHT_NORMAL)
        cr.set_font_size(11)
        cr.move_to(x1 + 12, y + win_h / 2 + 4)
        cr.show_text("Active window")

        # Inactive window
        if shadow_on:
            draw_shadow(cr, x2, y, win2_w, win_h, rounding, shadow_col)
        cr.set_source_rgba(0.10, 0.10, 0.13, inact_op)
        draw_rounded_rect(cr, x2, y, win2_w, win_h, rounding)
        cr.fill()
        ir, ig, ib, ia = _parse_hypr_color(inact_bdr)
        cr.set_source_rgba(ir, ig, ib, ia)
        cr.set_line_width(bsize)
        draw_rounded_rect(cr, x2 + bsize/2, y + bsize/2,
                           win2_w - bsize, win_h - bsize, rounding)
        cr.stroke()
        cr.set_source_rgba(0.5, 0.6, 0.5, 0.4)
        cr.set_font_size(11)
        cr.move_to(x2 + 12, y + win_h / 2 + 4)
        cr.show_text("Inactive")

    def _make_notebook(self):
        nb = Gtk.Notebook()
        nb.set_tab_pos(Gtk.PositionType.LEFT)
        nb.set_show_border(False)
        self._tab_defs = [
            ("󰄶  Presets",     self._page_presets),
            ("󰊠  Setup",       self._page_setup),
            ("󰔉  Appearance",  self._page_appearance),
            ("󰑊  Animations",  self._page_animations),
            ("󰌌  Input",       self._page_input),
            ("󰍹  Monitors",    self._page_monitors),
            ("󰘳  Keybindings", self._page_keybindings),
            ("󰊠  Rules",       self._page_rules),
            ("󰐛  Autostart",   self._page_autostart),
            ("󰙪  Environment", self._page_environment),
            ("󰕮  Plugins",     self._page_plugins),
            ("󰄾  Scripts",     self._page_scripts),
            ("󰆦  vsHub",       self._page_hub),
            ("󰋼  About",       self._page_about),
        ]
        self._tabs_built = set()
        for label, _ in self._tab_defs:
            placeholder = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
            lbl = Gtk.Label()
            lbl.set_markup(f'<span font_desc="JetBrainsMono Nerd Font 11">{label}</span>')
            lbl.set_xalign(0)
            nb.append_page(placeholder, lbl)
        self._nb = nb
        self._nb_plugins_idx = len(self._tab_defs) - 4  # index 10
        self._nb_hub_idx     = len(self._tab_defs) - 2  # index 12
        nb.connect("switch-page", self._on_tab_switch)
        self._build_tab(0)
        return nb

    def _build_tab(self, idx):
        if idx in self._tabs_built:
            return
        self._tabs_built.add(idx)
        _, builder = self._tab_defs[idx]
        content = builder()
        placeholder = self._nb.get_nth_page(idx)
        placeholder.pack_start(content, True, True, 0)
        placeholder.show_all()

    def _on_tab_switch(self, nb, page, idx):
        self._build_tab(idx)

    def _reload_tab(self, page_builder, idx, label, keep_position=False):
        """Rebuild a notebook tab in-place."""
        nb = self._nb
        was_current = nb.get_current_page() == idx
        nb.remove_page(idx)
        new_page = page_builder()
        lbl = Gtk.Label()
        lbl.set_markup(f'<span font_desc="JetBrainsMono Nerd Font 11">{label}</span>')
        lbl.set_xalign(0)
        nb.insert_page(new_page, lbl, idx)
        new_page.show_all()
        self._tabs_built.add(idx)
        if not keep_position or was_current:
            nb.set_current_page(idx)

    def _reload_hub_tab(self):
        self._reload_tab(self._page_hub, self._nb_hub_idx, "󰆦  vsHub", keep_position=True)

    def _reload_plugins_tab(self):
        self._reload_tab(self._page_plugins, self._nb_plugins_idx, "󰕮  Plugins")

