        btn_row.pack_start(write_all_btn, False, False, 0)
        btn_row.pack_end(run_btn,         False, False, 0)
        outer.pack_start(btn_row, False, False, 0)

        # ── Logic ─────────────────────────────────────────────────────────────
        def _current_path():
            idx = combo.get_active()
            if idx < 0: return None, None
            _, path, desc = self._SCRIPTS[idx]
            return os.path.expanduser(path), desc

        def _on_combo_change(cb):
            idx = cb.get_active()
            if idx < 0: return
            _, path, desc = self._SCRIPTS[idx]
            path_lbl.set_text(os.path.expanduser(path))
            desc_lbl.set_text(desc)
            tv.get_buffer().set_text(_load_script(path))
            p = os.path.expanduser(path)
            exec_chk.set_active(os.access(p, os.X_OK) if os.path.isfile(p) else True)

        combo.connect("changed", _on_combo_change)

        def _on_save(*_):
            path, _ = _current_path()
            if not path: return
            buf = tv.get_buffer()
            text = buf.get_text(buf.get_start_iter(), buf.get_end_iter(), True)
            # Backup
            if os.path.isfile(path):
                ts = datetime.datetime.now().strftime("%Y%m%d_%H%M%S")
                bk = os.path.join(_BACKUP, f"{ts}_{os.path.basename(path)}")
                os.makedirs(_BACKUP, exist_ok=True)
                shutil.copy2(path, bk)
            try:
                os.makedirs(os.path.dirname(path), exist_ok=True)
                with open(path, "w") as f:
                    f.write(text)
                if exec_chk.get_active():
                    os.chmod(path, 0o755)
                self._status("Script guardado: " + os.path.basename(path))
            except Exception as e:
                self._err(f"Error guardando script:\n{e}")

        def _on_reload(*_):
            idx = combo.get_active()
            if idx < 0: return
            _, path, _ = self._SCRIPTS[idx]
            tv.get_buffer().set_text(_load_script(path))

        def _on_default(*_):
            idx = combo.get_active()
            if idx < 0: return
            _, path, _ = self._SCRIPTS[idx]
            tv.get_buffer().set_text(_default_content(path))

        def _on_write_all(*_):
            written, skipped = [], []
            for _, path, _ in self._SCRIPTS:
                p = os.path.expanduser(path)
                if os.path.isfile(p):
                    skipped.append(os.path.basename(p))
                    continue
                content = _default_content(path)
                try:
                    os.makedirs(os.path.dirname(p), exist_ok=True)
                    with open(p, "w") as f:
                        f.write(content)
                    os.chmod(p, 0o755)
                    written.append(os.path.basename(p))
                except Exception as e:
                    self._err(f"Error writing {p}:\n{e}")
                    return
            msg = ""
            if written:
                msg += f"Written: {', '.join(written)}"
            if skipped:
                msg += ("\n" if msg else "") + f"Skipped (already exist): {', '.join(skipped)}"
            self._status(f"Scripts written: {len(written)}, skipped: {len(skipped)}")
            # Refresh editor with current selection
            _on_combo_change(combo)

        def _on_run(*_):
            path, _ = _current_path()
            if not path: return
            try:
                subprocess.Popen(["kitty", "-e", "bash", "-c",
                    f"bash '{path}'; echo; echo 'Listo — presiona Enter'; read"])
            except Exception as e:
                self._err(f"No se pudo ejecutar:\n{e}")

        save_btn.connect("clicked",      _on_save)
        reload_btn.connect("clicked",    _on_reload)
        default_btn.connect("clicked",   _on_default)
        write_all_btn.connect("clicked", _on_write_all)
        run_btn.connect("clicked",       _on_run)

        return outer

