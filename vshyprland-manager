    def _page_input(self):
        outer = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=4)
        outer.set_margin_start(20); outer.set_margin_end(20)
        outer.set_margin_top(14);   outer.set_margin_bottom(14)

        # Helper: ComboBoxText with EntryCompletion from a list of (code, name)
        def _xkb_combo(items, current_val):
            combo = Gtk.ComboBoxText(has_entry=True)
            entry = combo.get_child()
            store = Gtk.ListStore(str, str)   # code, label
            for code, name in items:
                label = f"{code} — {name}"
                combo.append(code, label)
                store.append([code, label])
            # EntryCompletion — matches on code and name
            comp = Gtk.EntryCompletion()
            comp.set_model(store)
            comp.set_text_column(1)
            comp.set_match_func(lambda c, key, it:
                key.lower() in store[it][0].lower() or
                key.lower() in store[it][1].lower()
            )
            def on_match(c, model, it):
                entry.set_text(model[it][0])
                entry.set_position(-1)
                return True
            comp.connect("match-selected", on_match)
            entry.set_completion(comp)
            entry.set_text(current_val)
            return combo, entry

        # ── Hot Corners (siempre visible) ─────────────────────────────────────────
        outer.pack_start(_section("Hot Corners"), False, False, 0)

        hc_row = Gtk.Box(spacing=16)
        hc_enabled = _switch(self._cfg.get("hotcorner.enabled", False))
        self._w["hotcorner.enabled"] = hc_enabled
        hc_row.pack_start(_row("Enable", hc_enabled), False, False, 0)
        hc_cool = _spin(self._cfg.get("hotcorner.cooldown", 1), 0, 10)
        self._w["hotcorner.cooldown"] = hc_cool
        hc_row.pack_start(_row("Cooldown (s)", hc_cool,
            tip="Minimum time between activations to avoid accidental triggers."), False, False, 0)
        hc_thr = _spin(self._cfg.get("hotcorner.threshold", 5), 1, 20)
        self._w["hotcorner.threshold"] = hc_thr
        hc_row.pack_start(_row("Zone (px)", hc_thr,
            tip="Pixels from the corner that activate the hot corner."), False, False, 0)
        outer.pack_start(hc_row, False, False, 6)

        t = self._theme
        hc_values = {}
        self._w["_hotcorner_values"] = hc_values

        _QUICK_ACTIONS = [
            ("No action",          ""),
            ("Workspace overview", "hyprctl dispatch hyprexpo:expo toggle"),
            ("Launcher (rofi)",    "rofi -show drun"),
            ("Launcher (wofi)",    "wofi --show drun"),
            ("Lock screen",        "hyprlock"),
            ("Notif. center",      "swaync-client -t"),
            ("Screenshot",         "grimblast copy area"),
            ("Clipboard",          "cliphist list | rofi -dmenu | cliphist decode | wl-copy"),
        ]

        _POS_ARROW = {"tl": "↖", "tr": "↗", "bl": "↙", "br": "↘"}
        _POS_LABEL = {"tl": "Top Left", "tr": "Top Right",
                      "bl": "Bottom Left", "br": "Bottom Right"}

        def _action_name(cmd):
            if not cmd: return "No action"
            for name, c in _QUICK_ACTIONS:
                if c == cmd: return name
            return cmd.split()[-1].split(":")[-1][:20]

        def _hex_to_rgb(h):
            h = h.lstrip("#")
            return tuple(int(h[i:i+2], 16) / 255 for i in (0, 2, 4))

        def _get_monitor_wp(_mon_name=None):
            """Return the wallpaper path the user set in the Appearance tab."""
            try:
                txt = open(os.path.expanduser("~/.config/hypr/wallpaper.sh")).read()
                m = re.search(r'awww img\s+"?([^"\n]+)"?', txt)
                if m:
                    return m.group(1).strip().replace("$HOME", os.path.expanduser("~"))
            except Exception:
                pass
            return None

        def _make_corner_btn(key, pos, redraw_cb):
            cmd = self._cfg.get(key, "")
            hc_values[key] = cmd
            arrow = _POS_ARROW[pos]

            btn = Gtk.Button()
            btn.get_style_context().add_class("open-btn")
            btn.set_size_request(148, 58)

            inner = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
            inner.set_margin_start(8); inner.set_margin_end(8)
            inner.set_margin_top(6);   inner.set_margin_bottom(6)
            arrow_lbl = Gtk.Label()
            arrow_lbl.set_markup(
                f'<span font_desc="JetBrainsMono Nerd Font 13" '
                f'foreground="{t["dim"]}">{arrow}</span>')
            action_lbl = Gtk.Label()
            action_lbl.set_line_wrap(True)
            action_lbl.set_max_width_chars(14)
            action_lbl.set_justify(Gtk.Justification.CENTER)
            inner.pack_start(arrow_lbl, False, False, 0)
            inner.pack_start(action_lbl, False, False, 0)
            btn.add(inner)

            def _update(c):
                name = _action_name(c)
                has = bool(c)
                color = t["acc"] if has else t["dim"]
                action_lbl.set_markup(
                    f'<span size="small" foreground="{color}"><b>{name}</b></span>')
                redraw_cb()

            _update(cmd)

            def _open_pop(b, k=key, p2=pos):
                pop = Gtk.Popover()
                pop.set_relative_to(b)
                pbox = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=4)
                pbox.set_margin_start(12); pbox.set_margin_end(12)
                pbox.set_margin_top(10);   pbox.set_margin_bottom(10)

                hdr = Gtk.Label()
                hdr.set_markup(
                    f'<b>{_POS_ARROW[p2]}  {_POS_LABEL[p2]}</b>')
                hdr.set_halign(Gtk.Align.START)
                pbox.pack_start(hdr, False, False, 0)
                pbox.pack_start(Gtk.Separator(), False, False, 4)

                for aname, acmd in _QUICK_ACTIONS:
                    ab = Gtk.Button(label=aname)
                    ab.get_style_context().add_class("open-btn")
                    if hc_values.get(k) == acmd:
                        ab.get_style_context().add_class("suggested-action")
                    def _pick(_, c=acmd, bk=k, p=pop):
                        hc_values[bk] = c
                        _update(c)
                        p.popdown()
                    ab.connect("clicked", _pick)
                    pbox.pack_start(ab, False, False, 0)

                pbox.pack_start(Gtk.Separator(), False, False, 4)
                cl = Gtk.Label(label="Comando personalizado:")
                cl.set_halign(Gtk.Align.START)
                pbox.pack_start(cl, False, False, 0)
                ce = Gtk.Entry()
                ce.set_text(hc_values.get(k, ""))
                ce.set_placeholder_text("hyprctl dispatch ...")
                ce.set_width_chars(40)
                def _custom(e, bk=k):
                    hc_values[bk] = e.get_text().strip()
                    _update(hc_values[bk])
                ce.connect("changed", _custom)
                ce.connect("activate", lambda e, p=pop: p.popdown())
                pbox.pack_start(ce, False, False, 0)

                pop.add(pbox)
                pbox.show_all()
                pop.popup()

            btn.connect("clicked", _open_pop)
            return btn

        def _make_monitor_tab(mon, nb):
            mname  = mon.get("name", "")
            label  = mname or "Monitor"
            wp_path = _get_monitor_wp(mname)

            WP_W, WP_H = 320, 200
            wp_pb = None
            if wp_path and os.path.isfile(wp_path):
                try:
                    wp_pb = GdkPixbuf.Pixbuf.new_from_file_at_scale(
                        wp_path, WP_W, WP_H, True)
                except Exception:
                    pass

            acc_r, acc_g, acc_b = _hex_to_rgb(t["acc"])

            da = Gtk.DrawingArea()
            da.set_size_request(WP_W, WP_H)

            def _redraw():
                da.queue_draw()

            def _draw(widget, cr, pb=wp_pb):
                w = widget.get_allocated_width()
                h = widget.get_allocated_height()
                radius = 10

                # Clip to rounded rect
                cr.new_path()
                cr.arc(radius, radius, radius, math.pi, 1.5 * math.pi)
                cr.arc(w - radius, radius, radius, 1.5 * math.pi, 0)
                cr.arc(w - radius, h - radius, radius, 0, 0.5 * math.pi)
                cr.arc(radius, h - radius, radius, 0.5 * math.pi, math.pi)
                cr.close_path()
                cr.clip()

                # Wallpaper or dark fallback
                if pb:
                    pb_w, pb_h = pb.get_width(), pb.get_height()
                    scale = max(w / pb_w, h / pb_h)
                    sw, sh = pb_w * scale, pb_h * scale
                    ox, oy = (w - sw) / 2, (h - sh) / 2
                    cr.save()
                    cr.translate(ox, oy)
                    cr.scale(scale, scale)
                    Gdk.cairo_set_source_pixbuf(cr, pb, 0, 0)
                    cr.paint()
                    cr.restore()
                else:
                    cr.set_source_rgb(0.07, 0.09, 0.05)
                    cr.rectangle(0, 0, w, h)
                    cr.fill()

                # Dark vignette overlay
                cr.set_source_rgba(0, 0, 0, 0.28)
                cr.rectangle(0, 0, w, h)
                cr.fill()

                # Corner triangles — accent if action set, subtle if not
                sz = 52
                corners_def = [
                    (f"hotcorner.{mname}.tl", [(0,0),(sz,0),(0,sz)]),
                    (f"hotcorner.{mname}.tr", [(w,0),(w-sz,0),(w,sz)]),
                    (f"hotcorner.{mname}.bl", [(0,h),(sz,h),(0,h-sz)]),
                    (f"hotcorner.{mname}.br", [(w,h),(w-sz,h),(w,h-sz)]),
                ]
                for key, pts in corners_def:
                    has = bool(hc_values.get(key, ""))
                    if has:
                        cr.set_source_rgba(acc_r, acc_g, acc_b, 0.82)
                    else:
                        cr.set_source_rgba(1, 1, 1, 0.10)
                    cr.move_to(*pts[0])
                    cr.line_to(*pts[1])
                    cr.line_to(*pts[2])
                    cr.close_path()
                    cr.fill()

                # Subtle border
                cr.set_source_rgba(1, 1, 1, 0.14)
                cr.set_line_width(1.5)
                cr.new_path()
                cr.arc(radius, radius, radius, math.pi, 1.5 * math.pi)
                cr.arc(w - radius, radius, radius, 1.5 * math.pi, 0)
                cr.arc(w - radius, h - radius, radius, 0, 0.5 * math.pi)
                cr.arc(radius, h - radius, radius, 0.5 * math.pi, math.pi)
                cr.close_path()
                cr.stroke()

            da.connect("draw", _draw)

            # Corner buttons
            tl = _make_corner_btn(f"hotcorner.{mname}.tl", "tl", _redraw)
            tr = _make_corner_btn(f"hotcorner.{mname}.tr", "tr", _redraw)
            bl = _make_corner_btn(f"hotcorner.{mname}.bl", "bl", _redraw)
            br = _make_corner_btn(f"hotcorner.{mname}.br", "br", _redraw)

            tl.set_valign(Gtk.Align.END);   tl.set_halign(Gtk.Align.END)
            tr.set_valign(Gtk.Align.END);   tr.set_halign(Gtk.Align.START)
            bl.set_valign(Gtk.Align.START); bl.set_halign(Gtk.Align.END)
            br.set_valign(Gtk.Align.START); br.set_halign(Gtk.Align.START)

            # Grid: col0=left btns, col1=wallpaper, col2=right btns
            grid = Gtk.Grid()
            grid.set_column_spacing(10)
            grid.set_row_spacing(6)
            grid.set_halign(Gtk.Align.CENTER)
            grid.set_valign(Gtk.Align.CENTER)
            grid.attach(tl, 0, 0, 1, 1)
            grid.attach(tr, 2, 0, 1, 1)
            grid.attach(da, 1, 0, 1, 2)
            grid.attach(bl, 0, 1, 1, 1)
            grid.attach(br, 2, 1, 1, 1)

            tab_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
            tab_box.set_margin_start(12); tab_box.set_margin_end(12)
            tab_box.set_margin_top(16);   tab_box.set_margin_bottom(16)
            tab_box.pack_start(grid, False, False, 0)

            nb.append_page(tab_box, Gtk.Label(label=label))

        # Build per-monitor notebook
        hc_nb = Gtk.Notebook()
        hc_nb.set_tab_pos(Gtk.PositionType.TOP)
        hc_nb.set_margin_top(8)

        try:
            raw = subprocess.check_output(
                ["hyprctl", "monitors", "-j"], text=True, stderr=subprocess.DEVNULL)
