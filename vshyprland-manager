# ── XKB layout/variant data ────────────────────────────────────────────────────

def _load_xkb_data():
    layouts  = []          # [(code, name), ...]
    variants = {}          # {layout_code: [(code, name), ...]}
    try:
        text = open("/usr/share/X11/xkb/rules/evdev.lst").read()
        m = re.search(r'! layout\n(.*?)(?=\n! |\Z)', text, re.DOTALL)
        if m:
            for line in m.group(1).strip().splitlines():
                parts = line.strip().split(None, 1)
                if len(parts) == 2:
                    layouts.append((parts[0], parts[1]))
        m2 = re.search(r'! variant\n(.*?)(?=\n! |\Z)', text, re.DOTALL)
        if m2:
            for line in m2.group(1).strip().splitlines():
                parts = line.strip().split(None, 1)
                if len(parts) == 2:
                    vcode, rest = parts
                    # rest format: "layout_code: Description"
                    cm = re.match(r'(\w+)\s*:\s*(.*)', rest)
                    if cm:
                        lcode, desc = cm.group(1), cm.group(2).strip()
                        variants.setdefault(lcode, []).append((vcode, desc))
    except Exception:
        pass
    return layouts, variants

_XKB_LAYOUTS, _XKB_VARIANTS = _load_xkb_data()

# ── file parsers ───────────────────────────────────────────────────────────────

def _parse_border_gradient(s):
    """Split 'rgba(c1) rgba(c2) Ndeg' into (c1, c2). Falls back gracefully."""
    parts = s.strip().split()
    colors = [p for p in parts if p.startswith('rgba(') or p.startswith('rgb(')]
    if len(colors) >= 2:
        return colors[0], colors[1]
    elif len(colors) == 1:
        return colors[0], colors[0]
    return "rgba(89b4faff)", "rgba(cba6f7ff)"

def parse_appearance(text):
    gen  = _extract_block(text, "general")
    deco = _extract_block(text, "decoration")
    shad = _extract_nested(text, "decoration", "shadow")
    blr  = _extract_nested(text, "decoration", "blur")
    xway = _extract_block(text, "xwayland")
    return {
        "general.gaps_in":             _parse_int(gen,   "gaps_in",             5),
        "general.gaps_out":            _parse_int(gen,   "gaps_out",            10),
        "general.border_size":         _parse_int(gen,   "border_size",         2),
        "general.col.active_border":   _parse_scalar(gen,"col.active_border",   "rgba(89b4faff) rgba(cba6f7ff) 45deg"),
        "general.col.inactive_border": _parse_scalar(gen,"col.inactive_border", "rgba(313244aa)"),
        "general.resize_on_border":    _parse_bool(gen,  "resize_on_border",    True),
        "general.allow_tearing":       _parse_bool(gen,  "allow_tearing",       False),
        "general.layout":              _parse_scalar(gen,"layout",              "dwindle"),
        "decoration.rounding":          _parse_int(deco,  "rounding",            10),
        "decoration.active_opacity":   _parse_float(deco,"active_opacity",      1.0),
