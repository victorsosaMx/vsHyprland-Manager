        def update_layout_name(*_):
            code = kb_entry.get_text().strip()
            name = next((n for c, n in _XKB_LAYOUTS if c == code), "")
            kb_name_lbl.set_text(name)
            vr_store.clear()
            for vc, vn in _XKB_VARIANTS.get(code, []):
                vr_combo.append(vc, f"{vc} — {vn}")
                vr_store.append([vc, f"{vc} — {vn}"])
        kb.pack_start(_row("Layout", kb_combo,
            tip="Keyboard layout. Type to search or pick from the list.\n"
                "Examples: us, latam, es, de, fr, br, ru"), False, False, 4)
        kb.pack_start(kb_name_lbl, False, False, 0)

        cur_variant = self._cfg.get("input.kb_variant", "")
        vr_combo = Gtk.ComboBoxText(has_entry=True)
        vr_entry = vr_combo.get_child()
        vr_store = Gtk.ListStore(str, str)
        for vc, vn in _XKB_VARIANTS.get(cur_layout, []):
            vr_combo.append(vc, f"{vc} — {vn}")
            vr_store.append([vc, f"{vc} — {vn}"])
        vr_comp = Gtk.EntryCompletion()
        vr_comp.set_model(vr_store)
        vr_comp.set_text_column(1)
        vr_comp.set_match_func(lambda c, key, it:
            key.lower() in vr_store[it][0].lower() or
            key.lower() in vr_store[it][1].lower()
        )
        def on_var_match(c, model, it):
            vr_entry.set_text(model[it][0]); vr_entry.set_position(-1); return True
        vr_comp.connect("match-selected", on_var_match)
        vr_entry.set_completion(vr_comp)
        vr_entry.set_text(cur_variant)
        self._w["input.kb_variant"] = vr_entry
        kb_entry.connect("changed", update_layout_name)
        update_layout_name()
