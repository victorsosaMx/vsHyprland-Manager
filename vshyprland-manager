                 "Recommended cursor theme (AUR)"),
            ]),
        ]

        def _pacman_installed(pkg):
            try:
                r = subprocess.run(["pacman", "-Q", pkg],
                                   stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
                return r.returncode == 0
            except Exception:
                return False

        def _check_dep(cmd, pkg, special):
            if special == "_hypr_sig":
                return bool(os.environ.get("HYPRLAND_INSTANCE_SIGNATURE"))
            if special == "_polkit":
                return os.path.isfile("/usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1")
            if special == "_font_jbm":
                try:
                    out = subprocess.check_output(["fc-list", ":family=JetBrainsMono Nerd Font"],
                                                   stderr=subprocess.DEVNULL).decode()
                    return bool(out.strip())
                except Exception:
                    return False
            if special == "_font_emoji":
                try:
                    out = subprocess.check_output(["fc-list", ":family=Noto Color Emoji"],
                                                   stderr=subprocess.DEVNULL).decode()
                    return bool(out.strip())
                except Exception:
                    return False
            if special == "_cursor_bib":
                return (os.path.isdir("/usr/share/icons/Bibata-Modern-Classic") or
                        os.path.isdir(os.path.expanduser("~/.local/share/icons/Bibata-Modern-Classic")))
            if special == "_xdph":
                return _pacman_installed("xdg-desktop-portal-hyprland")
            if special == "_xdp":
                return _pacman_installed("xdg-desktop-portal")
            if cmd:
                # Try which first, then pacman as fallback
                return shutil.which(cmd) is not None or (pkg and _pacman_installed(pkg))
            return False

        t = self._theme
        outer = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        outer.set_margin_start(20); outer.set_margin_end(20)
        outer.set_margin_top(14);   outer.set_margin_bottom(14)

        outer.pack_start(_section("Environment Setup"), False, False, 0)
        outer.pack_start(_hint(
            "Checks all tools and packages needed for vsHyprland to work correctly.\n"
            "Install missing items, then click Refresh."
        ), False, False, 6)

        # Refresh button
        refresh_btn = Gtk.Button(label="⟳  Refresh")
        refresh_btn.get_style_context().add_class("open-btn")
        refresh_btn.set_halign(Gtk.Align.START)
        refresh_btn.set_margin_top(4)
        refresh_btn.set_margin_bottom(8)
        outer.pack_start(refresh_btn, False, False, 0)

        results_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        outer.pack_start(results_box, False, False, 0)

        missing_pacman = []
        missing_aur    = []

        def _build_results():
            for ch in list(results_box.get_children()):
                results_box.remove(ch)
            missing_pacman.clear()
            missing_aur.clear()

            for group_name, items in _DEPS:
                results_box.pack_start(_section(group_name), False, False, 0)
                for (label, cmd, pkg, special, desc) in items:
                    ok = _check_dep(cmd, pkg, special)
                    row = Gtk.Box(spacing=10)
                    row.set_margin_start(4)
                    row.set_margin_top(3); row.set_margin_bottom(3)

                    status = Gtk.Label()
                    if ok:
                        status.set_markup(f'<span foreground="#a6e3a1" weight="bold">✓</span>')
                    else:
                        status.set_markup(f'<span foreground="#f38ba8" weight="bold">✗</span>')
                    status.set_size_request(20, -1)

                    name_lbl = Gtk.Label(label=label)
                    name_lbl.set_xalign(0)
                    name_lbl.set_size_request(220, -1)
                    if not ok:
                        name_lbl.set_markup(f'<b>{label}</b>')

                    desc_lbl = Gtk.Label(label=desc)
                    desc_lbl.set_xalign(0)
                    desc_lbl.get_style_context().add_class("hint-label")

                    row.pack_start(status,   False, False, 0)
                    row.pack_start(name_lbl, False, False, 0)
                    row.pack_start(desc_lbl, False, False, 0)
                    results_box.pack_start(row, False, False, 0)

                    if not ok and pkg:
                        if "bin" in pkg or pkg in ("bibata-cursor-theme-bin",):
                            missing_aur.append(pkg)
                        else:
                            missing_pacman.append(pkg)

            # Portal start button — always shown when portals are installed
            if _pacman_installed("xdg-desktop-portal-hyprland"):
                portal_btn = Gtk.Button(label="▶  Start XDG Portals now")
                portal_btn.get_style_context().add_class("open-btn")
                portal_btn.set_halign(Gtk.Align.START)
                portal_btn.set_tooltip_text(
                    "Runs: dbus-update-activation-environment + systemctl --user start\n"
                    "Fixes the portal DBus error without restarting the session."
                )
                portal_btn.connect("clicked", lambda *_: self._run_in_terminal([
                    "dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP",
                    "systemctl --user start xdg-desktop-portal xdg-desktop-portal-hyprland",
                    "echo 'Portals started successfully'",
                ], on_done=lambda: GLib.idle_add(_build_results)))
                results_box.pack_start(portal_btn, False, False, 4)

            # Install buttons
            results_box.pack_start(Gtk.Separator(), False, False, 12)
            if missing_pacman:
                cmd_str = "sudo pacman -S --needed " + " ".join(missing_pacman)
                btn = Gtk.Button(label=f"Install {len(missing_pacman)} missing (pacman)")
                btn.get_style_context().add_class("save-btn")
                btn.set_halign(Gtk.Align.START)
                btn.connect("clicked", lambda *_: self._run_in_terminal(
                    [cmd_str], on_done=lambda: GLib.idle_add(_build_results)
                ))
                results_box.pack_start(btn, False, False, 4)

            if missing_aur:
                _aur_helper = next((h for h in ("yay", "paru") if shutil.which(h)), "yay")
                cmd_str = f"{_aur_helper} -S --needed " + " ".join(missing_aur)
                btn = Gtk.Button(label=f"Install {len(missing_aur)} missing (AUR/{_aur_helper})")
                btn.get_style_context().add_class("open-btn")
                btn.set_halign(Gtk.Align.START)
                btn.connect("clicked", lambda *_: self._run_in_terminal(
                    [cmd_str], on_done=lambda: GLib.idle_add(_build_results)
                ))
                results_box.pack_start(btn, False, False, 4)

            if not missing_pacman and not missing_aur:
                ok_lbl = Gtk.Label()
                ok_lbl.set_markup(f'<span foreground="#a6e3a1" weight="bold">✓ All dependencies satisfied</span>')
                ok_lbl.set_halign(Gtk.Align.START)
                ok_lbl.set_margin_top(4)
                results_box.pack_start(ok_lbl, False, False, 0)

            results_box.show_all()

        _build_results()
        refresh_btn.connect("clicked", lambda *_: _build_results())

        # ── Plugin Manager ────────────────────────────────────────────────────
        outer.pack_start(_section("Plugin Manager"), False, False, 8)
        outer.pack_start(_hint(
            "On a fresh install, hyprpm needs to download headers before plugins can be added.\n"
            "Run this once — the Plugins tab will handle it automatically when adding repos."
        ), False, False, 6)

        hyprpm_btn = Gtk.Button(label="⟳  Update plugin headers (hyprpm update)")
        hyprpm_btn.get_style_context().add_class("open-btn")
        hyprpm_btn.set_halign(Gtk.Align.START)
        hyprpm_btn.set_tooltip_text(
            "Runs: hyprpm update\n"
            "Required once on fresh installs before adding plugin repositories."
        )
        hyprpm_btn.connect("clicked", lambda *_: self._run_in_terminal(
            ["hyprpm update"],
            on_done=None
        ))
        outer.pack_start(hyprpm_btn, False, False, 4)

        return outer

