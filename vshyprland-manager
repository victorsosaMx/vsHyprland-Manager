    def _page_appearance(self):
        outer = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=4)
        outer.set_margin_start(20); outer.set_margin_end(20)
        outer.set_margin_top(14);   outer.set_margin_bottom(14)

        # ── Wallpaper ─────────────────────────────────────────────────────────
        outer.pack_start(_section("Wallpaper"), False, False, 0)

        _WP_SCRIPT   = os.path.expanduser("~/.config/hypr/wallpaper.sh")
        _WP_DEFAULT  = os.path.expanduser("~/.config/hypr/wallpaper.jpg")
        _TRANSITIONS = ["grow", "fade", "left", "right", "top", "bottom",
                        "wipe", "wave", "outer", "any", "random", "none"]
        _WP_DIRS     = [
            os.path.expanduser("~/Pictures"),
            os.path.expanduser("~/Wallpapers"),
            os.path.expanduser("~/Images"),
            os.path.expanduser("~/.local/share/wallpapers"),
            "/usr/share/backgrounds",
        ]
        _IMG_EXTS = {".jpg", ".jpeg", ".png", ".webp", ".gif"}

        def _read_wp_script():
            try:    return open(_WP_SCRIPT).read()
            except: return ""

        def _parse_wp(text):
            img, trans, dur = _WP_DEFAULT, "grow", "1"
            m = re.search(r'awww img\s+"?([^"\\]+)"?', text)
            if m: img = m.group(1).strip().replace("$HOME", os.path.expanduser("~"))
            m = re.search(r'--transition-type\s+(\S+)', text)
            if m: trans = m.group(1)
            m = re.search(r'--transition-duration\s+(\S+)', text)
            if m: dur = m.group(1)
            return img, trans, dur

        def _write_wp_script(img, trans, dur):
            img_sh = img.replace(os.path.expanduser("~"), "$HOME")
            content = (
                "#!/bin/bash\n# Wallpaper script — managed by vsHyprland-Manager\n"
                "sleep 1\nawww-daemon &\nsleep 0.5\n"
                f'awww img "{img_sh}" \\\n'
                f'    --transition-type {trans} \\\n'
                f'    --transition-pos 0.5,0.5 \\\n'
                f'    --transition-duration {dur}\n'
            )
            os.makedirs(os.path.dirname(_WP_SCRIPT), exist_ok=True)
            with open(_WP_SCRIPT, "w") as f: f.write(content)
            os.chmod(_WP_SCRIPT, 0o755)

        def _load_pixbuf(path, w, h):
            try:
                pb = GdkPixbuf.Pixbuf.new_from_file_at_scale(path, w, h, True)
                return pb
            except Exception:
                return None

        def _scan_wallpapers():
            found = []
            for d in _WP_DIRS:
                if not os.path.isdir(d): continue
                for fn in sorted(os.listdir(d)):
                    if os.path.splitext(fn)[1].lower() in _IMG_EXTS:
                        found.append(os.path.join(d, fn))
                if found: break
            return found[:40]

        _img0, _trans0, _dur0 = _parse_wp(_read_wp_script())
        _current_path = [_img0]

        t = self._theme

        # ── Main preview ──────────────────────────────────────────────────
        PREV_W, PREV_H = 480, 200

        preview_da = Gtk.DrawingArea()
        preview_da.set_size_request(PREV_W, PREV_H)
        preview_da.get_style_context().add_class("plugin-card")

        _preview_pb = [_load_pixbuf(_img0, PREV_W * 2, PREV_H * 2)]

        def _draw_preview(widget, cr):
            w = widget.get_allocated_width()
            h = widget.get_allocated_height()
            pb = _preview_pb[0]
            if pb:
                # Scale to fill keeping aspect
                scale = max(w / pb.get_width(), h / pb.get_height())
                sw = int(pb.get_width() * scale)
                sh = int(pb.get_height() * scale)
                scaled = pb.scale_simple(sw, sh, GdkPixbuf.InterpType.BILINEAR)
                ox = (w - sw) // 2
                oy = (h - sh) // 2
                Gdk.cairo_set_source_pixbuf(cr, scaled, ox, oy)
                cr.paint()
            else:
                # Placeholder
                cr.set_source_rgb(0.12, 0.14, 0.11)
                cr.rectangle(0, 0, w, h)
                cr.fill()
                cr.set_source_rgba(0.4, 0.5, 0.35, 0.6)
                cr.select_font_face("Sans", 0, 0)
                cr.set_font_size(13)
                msg = "No wallpaper selected"
                te = cr.text_extents(msg)
                cr.move_to((w - te[2]) / 2, (h + te[3]) / 2)
                cr.show_text(msg)

        preview_da.connect("draw", _draw_preview)
        outer.pack_start(preview_da, False, False, 6)

        # ── Path + browse ─────────────────────────────────────────────────
        wp_row = Gtk.Box(spacing=8)
        wp_entry = Gtk.Entry()
        wp_entry.set_text(_img0)
        wp_entry.set_hexpand(True)
        wp_entry.set_placeholder_text("Path to wallpaper image…")

        def _set_wallpaper(path):
            _current_path[0] = path
            wp_entry.set_text(path)
            _preview_pb[0] = _load_pixbuf(path, PREV_W * 2, PREV_H * 2)
            preview_da.queue_draw()

        def _browse(*_):
            dlg = Gtk.FileChooserDialog(
                title="Select wallpaper", parent=self,
                action=Gtk.FileChooserAction.OPEN)
            dlg.add_buttons(Gtk.STOCK_CANCEL, Gtk.ResponseType.CANCEL,
                            Gtk.STOCK_OPEN,   Gtk.ResponseType.OK)
            ff = Gtk.FileFilter()
            ff.set_name("Images")
            for pat in ("*.jpg","*.jpeg","*.png","*.webp","*.gif"): ff.add_pattern(pat)
            dlg.add_filter(ff)
            try:
                cur = wp_entry.get_text().strip()
                if os.path.isfile(cur): dlg.set_filename(cur)
                elif os.path.isdir(os.path.dirname(cur)): dlg.set_current_folder(os.path.dirname(cur))
            except: pass
            if dlg.run() == Gtk.ResponseType.OK:
                _set_wallpaper(dlg.get_filename())
            dlg.destroy()

        browse_btn = Gtk.Button(label="  Browse…")
        browse_btn.get_style_context().add_class("open-btn")
        browse_btn.connect("clicked", _browse)
        wp_entry.connect("activate", lambda e: _set_wallpaper(e.get_text().strip()))
        wp_row.pack_start(wp_entry,   True,  True,  0)
        wp_row.pack_start(browse_btn, False, False, 0)
        outer.pack_start(wp_row, False, False, 4)

        # ── Transition + duration + apply ─────────────────────────────────
        ctrl_row = Gtk.Box(spacing=12)
        tr_combo = _combo(_TRANSITIONS, _trans0)
        dur_spin = _spin(float(_dur0), 0.1, 10.0, step=0.1, digits=1)
        ctrl_row.pack_start(_row("Transition", tr_combo), False, False, 0)
        ctrl_row.pack_start(_row("Duration (s)", dur_spin), False, False, 0)

        apply_wp_btn = Gtk.Button(label="▶  Apply now")
        apply_wp_btn.get_style_context().add_class("save-btn")
        apply_wp_btn.set_valign(Gtk.Align.CENTER)

        def _apply_wp(*_):
            img   = wp_entry.get_text().strip()
            trans = tr_combo.get_active_text() or "grow"
            dur   = f"{dur_spin.get_value():.1f}"
            if not img: return
            _set_wallpaper(img)
            _write_wp_script(img, trans, dur)
            # Ensure wallpaper.sh is in autostart for persistence across reboots
            auto = self._cfg.setdefault("autostart", [])
            if not any(_WP_SCRIPT in e.get("cmd", "") for e in auto):
                auto.append({"enabled": True, "cmd": _WP_SCRIPT, "name": "Wallpaper"})
                try:
                    from_disk = open(os.path.expanduser("~/.config/hypr/modules/autostart.conf")).read()
                except Exception:
