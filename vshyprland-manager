# ── parser helpers ─────────────────────────────────────────────────────────────

def _extract_block(text, section):
    """Extract content between braces of 'section { ... }' using brace-depth counting."""
    m = re.search(rf'\b{re.escape(section)}\s*\{{', text)
    if not m:
        return ""
    start = m.end(); depth = 1; i = start
    while i < len(text) and depth > 0:
        if text[i] == '{':
            depth += 1
        elif text[i] == '}':
            depth -= 1
        i += 1
    return text[start:i-1]

def _extract_nested(text, outer, inner):
    return _extract_block(_extract_block(text, outer), inner)

def _extract_all_blocks(text, section):
    """Return list of content strings for all 'section { ... }' blocks."""
    results = []; search = text
    while True:
        m = re.search(rf'\b{re.escape(section)}\s*\{{', search)
        if not m:
            break
        start = m.end(); depth = 1; i = start
        while i < len(search) and depth > 0:
            if search[i] == '{': depth += 1
            elif search[i] == '}': depth -= 1
            i += 1
        results.append(search[start:i-1])
        search = search[i:]
    return results

def _remove_all_blocks(text, section):
    """Remove all occurrences of 'section { ... }' blocks."""
    result = text
    while True:
        m = re.search(rf'\b{re.escape(section)}\s*\{{', result)
        if not m:
            break
        start = m.start(); i = m.end(); depth = 1
        while i < len(result) and depth > 0:
            if result[i] == '{': depth += 1
            elif result[i] == '}': depth -= 1
            i += 1
        result = result[:start] + result[i:]
    return result

def _parse_scalar(text, key, default=""):
    m = re.search(rf'^[ \t]*{re.escape(key)}[ \t]*=[ \t]*(.+)$', text, re.MULTILINE)
    return m.group(1).strip() if m else default

def _parse_bool(text, key, default=False):
    v = _parse_scalar(text, key, None)
    if v is None:
        return default
    return v.lower() in ("true", "yes", "1", "on")

def _parse_int(text, key, default=0):
    v = _parse_scalar(text, key, None)
    try:
        return int(float(v)) if v is not None else default
    except Exception:
        return default

def _parse_float(text, key, default=0.0):
    v = _parse_scalar(text, key, None)
    try:
        return float(v) if v is not None else default
    except Exception:
        return default

def _parse_hypr_color(s):
    """rgba(rrggbbaa) or rgb(rrggbb) → (r,g,b,a) floats. Gradient → first color."""
    s = s.strip()
    if ' ' in s:
        s = s.split()[0]
    m = re.match(r'rgba\(([0-9a-fA-F]{6})([0-9a-fA-F]{2})\)', s)
    if m:
        h, a = m.group(1), m.group(2)
        return (int(h[0:2], 16)/255, int(h[2:4], 16)/255, int(h[4:6], 16)/255, int(a, 16)/255)
    m = re.match(r'rgb\(([0-9a-fA-F]{6})\)', s)
    if m:
        h = m.group(1)
        return (int(h[0:2], 16)/255, int(h[2:4], 16)/255, int(h[4:6], 16)/255, 1.0)
    return (0.5, 0.5, 0.5, 1.0)

def _gdk_to_hypr(rgba):
    """Gdk.RGBA → rgba(rrggbbaa) string."""
    r = int(rgba.red * 255)
    g = int(rgba.green * 255)
    b = int(rgba.blue * 255)
    a = int(rgba.alpha * 255)
    return f"rgba({r:02x}{g:02x}{b:02x}{a:02x})"

def _hypr_to_gdk(s):
    r, g, b, a = _parse_hypr_color(s)
    c = Gdk.RGBA()
    c.red = r; c.green = g; c.blue = b; c.alpha = a
    return c

def _replace_block(text, section, new_content):
    """Replace 'section { ... }' block preserving surrounding text."""
    m = re.search(rf'\b{re.escape(section)}\s*\{{', text)
    if not m:
        return text + f"\n{section} {{\n{new_content}\n}}\n"
    start = m.end(); depth = 1; i = start
    while i < len(text) and depth > 0:
        if text[i] == '{':
            depth += 1
        elif text[i] == '}':
            depth -= 1
        i += 1
    return text[:m.start()] + f"{section} {{\n{new_content}}}" + text[i:]

