        outer.pack_start(hc_nb, False, False, 0)

        # ── Tabs: Keyboard / Mouse / Touchpad / Layouts / Misc ───────────────
        inp_nb = Gtk.Notebook()
        inp_nb.set_tab_pos(Gtk.PositionType.TOP)
        inp_nb.set_margin_top(8)

        # ── Keyboard tab ─────────────────────────────────────────────────────
