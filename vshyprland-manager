    }

def parse_animations(text):
    # Try dedicated animations block first; fall back to top-level text
    anim = _extract_block(text, "animations")
    if not anim:
        anim = text
    beziers = []
    for m in re.finditer(
        r'^\s*bezier\s*=\s*(\w+),\s*([\d.]+),\s*([\d.]+),\s*([\d.]+),\s*([\d.]+)',
        anim, re.MULTILINE
    ):
        beziers.append((
            m.group(1),
            float(m.group(2)), float(m.group(3)),
            float(m.group(4)), float(m.group(5))
        ))
    anims = []
    for m in re.finditer(
        r'^\s*animation\s*=\s*(\w+),\s*(\d+),\s*(\d+),\s*(\w+)(?:,\s*(.+?))?$',
        anim, re.MULTILINE
    ):
        anims.append((
            m.group(1), int(m.group(2)), int(m.group(3)),
            m.group(4), (m.group(5) or "").strip()
        ))
    if not beziers:
        beziers = [
            ("easeOut",  0.05, 0.9,  0.1,  1.05),
            ("linear",   0.0,  0.0,  1.0,  1.0),
            ("overshot", 0.13, 0.99, 0.29, 1.1),
        ]
    if not anims:
        anims = [
            ("windows",    1, 5,  "overshot", "slide"),
            ("windowsOut", 1, 4,  "easeOut",  "slide"),
            ("border",     1, 10, "default",  ""),
            ("borderangle",1, 8,  "linear",   "loop"),
            ("fade",       1, 5,  "default",  ""),
            ("workspaces", 1, 5,  "overshot", "slidevert"),
        ]
    return {
        "animations.enabled":    _parse_bool(anim, "enabled", True),
        "animations.beziers":    beziers,
        "animations.animations": anims,
    }

def _parse_kb_options(inp_block):
    """Parse kb_options safely — guard against corrupt lines like:
       kb_options = numlock_by_default = true   (which is actually two separate keys)."""
    val = _parse_scalar(inp_block, "kb_options", "")
    # If the value looks like "key = something", it's a corrupt line — return empty.
    if re.match(r'^\w+\s*=', val):
        return ""
    return val

