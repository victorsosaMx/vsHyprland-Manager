    def _draw_preset_preview(self, widget, cr, cfg):
        w = widget.get_allocated_width()
        h = widget.get_allocated_height()

        rad  = min(cfg.get("decoration.rounding", 0), 16)
        bsz  = min(max(1, cfg.get("general.border_size", 2)), 5)
        c1   = cfg.get("_border_color1", "rgba(89b4faff)")
        c2   = cfg.get("_border_color2", c1)
        inop = cfg.get("decoration.inactive_opacity", 1.0)
        gaps = min(cfg.get("general.gaps_out", 8), 12)
        has_shadow = cfg.get("shadow.enabled", False)
        has_blur   = cfg.get("blur.enabled", False)
        dim_inact  = cfg.get("decoration.dim_inactive", False)

        br1, bg1, bb1, ba1 = _parse_hypr_color(c1)
        br2, bg2, bb2, ba2 = _parse_hypr_color(c2)

        def rr(cr, x, y, ww, hh, r_):
            r_ = min(r_, ww / 2, hh / 2)
            cr.new_path()
            cr.arc(x+r_,    y+r_,    r_, math.pi,    3*math.pi/2)
            cr.arc(x+ww-r_, y+r_,    r_, -math.pi/2, 0)
            cr.arc(x+ww-r_, y+hh-r_, r_, 0,           math.pi/2)
            cr.arc(x+r_,    y+hh-r_, r_, math.pi/2,   math.pi)
            cr.close_path()

        # ── Desktop background ────────────────────────────────────────────────
        cr.set_source_rgb(0.07, 0.07, 0.10)
        cr.paint()

        # ── Top color stripe (preset identity) ───────────────────────────────
        stripe_h = 4
        lg = cairo.LinearGradient(0, 0, w, 0)
        lg.add_color_stop_rgba(0,   br1, bg1, bb1, ba1)
        lg.add_color_stop_rgba(0.6, br2, bg2, bb2, ba2)
        lg.add_color_stop_rgba(1.0, br1, bg1, bb1, ba1 * 0.4)
        cr.set_source(lg)
        cr.rectangle(0, 0, w, stripe_h)
        cr.fill()

        # ── Simulated Waybar strip ─────────────────────────────────────────
        bar_h = 12
        cr.set_source_rgba(br1, bg1, bb1, 0.12)
        cr.rectangle(0, stripe_h, w, bar_h)
        cr.fill()
        # tiny bar dots (left modules)
        dot_x = 8
        for _ in range(3):
            cr.set_source_rgba(br1, bg1, bb1, 0.5)
            cr.arc(dot_x, stripe_h + bar_h / 2, 2.5, 0, 2 * math.pi)
            cr.fill()
            dot_x += 10
        # center clock pill
        clock_w = 30
        clock_x = w / 2 - clock_w / 2
        cr.set_source_rgba(br1, bg1, bb1, 0.2)
        rr(cr, clock_x, stripe_h + 2, clock_w, bar_h - 4, 3)
        cr.fill()

        # ── Window area ───────────────────────────────────────────────────────
        top_offset = stripe_h + bar_h + gaps
        avail_h = h - top_offset - gaps
        avail_w = w - gaps * 2

        gap_between = max(4, gaps // 2)
        w1 = int((avail_w - gap_between) * 0.58)
        w2 = avail_w - w1 - gap_between
        x1 = gaps
        x2 = gaps + w1 + gap_between

        inact_dim = 0.55 if dim_inact else inop * 0.85
        inact_fill = inop * (0.7 if has_blur else 0.9)

        # Shadow under active window
        if has_shadow:
            for i in range(5, 0, -1):
                alpha = 0.06 * i
                spread = i * 1.5
                cr.set_source_rgba(0, 0, 0, alpha)
                rr(cr, x1 - spread, top_offset - spread + 2,
                   w1 + spread * 2, avail_h + spread * 2, rad + spread)
                cr.fill()

        # Inactive window
        inact_alpha = inact_fill * inact_dim
        cr.set_source_rgba(0.12, 0.12, 0.18, inact_alpha)
        rr(cr, x2, top_offset, w2, avail_h, rad)
        cr.fill()
        # Inactive window content lines
        cr.set_source_rgba(1, 1, 1, 0.04)
        for li in range(3):
            ly = top_offset + 8 + li * 7
            lw = w2 * (0.7 - li * 0.1)
            cr.rectangle(x2 + 6, ly, lw, 3)
            cr.fill()
        # Inactive border
        cr.set_source_rgba(0.3, 0.3, 0.4, 0.35)
        cr.set_line_width(1)
        rr(cr, x2 + 0.5, top_offset + 0.5, w2 - 1, avail_h - 1, rad)
        cr.stroke()

        # Active window fill
        cr.set_source_rgba(0.11, 0.11, 0.16, 0.95)
        rr(cr, x1, top_offset, w1, avail_h, rad)
        cr.fill()
        # Active window content lines
        cr.set_source_rgba(br1, bg1, bb1, 0.08)
        for li in range(4):
            ly = top_offset + 8 + li * 8
            lw = w1 * (0.75 - li * 0.08)
            cr.rectangle(x1 + 8, ly, lw, 3)
            cr.fill()
        # Blur hint on active window (if blur)
        if has_blur:
            cr.set_source_rgba(br1, bg1, bb1, 0.04)
            rr(cr, x1, top_offset, w1, avail_h, rad)
            cr.fill()
        # Active window border (gradient if c1 != c2)
        cr.set_line_width(bsz)
        if c1 != c2:
            lg2 = cairo.LinearGradient(x1, top_offset, x1 + w1, top_offset + avail_h)
            lg2.add_color_stop_rgba(0,   br1, bg1, bb1, ba1)
            lg2.add_color_stop_rgba(1.0, br2, bg2, bb2, ba2)
            cr.set_source(lg2)
        else:
            cr.set_source_rgba(br1, bg1, bb1, ba1)
        half = bsz / 2
        rr(cr, x1 + half, top_offset + half, w1 - bsz, avail_h - bsz, rad)
        cr.stroke()

    def _apply_hypr_preset(self, btn, name):
        data = _HYPR_PRESETS.get(name)
        if not data:
            return

        # Apply appearance values to self._cfg
        self._cfg.update(data["cfg"])

        # Apply optional full-environment fields
        if "autostart" in data:
            self._cfg["autostart"] = [dict(e) for e in data["autostart"]]
        if "env" in data:
            self._cfg["env"] = list(data["env"])
        if "rules" in data:
            r = data["rules"]
            self._cfg["windowrules"] = [dict(x) for x in r.get("windowrules", [])]
            self._cfg["layerrules"]  = list(r.get("layerrules", []))
            self._cfg["blurls"]      = list(r.get("blurls", []))
        if "variables" in data:
            self._cfg["variables"] = dict(data["variables"])
        if "binds" in data:
            self._cfg["binds"] = [dict(b) for b in data["binds"]]

        # Apply animation preset into cfg (before rebuild)
        anim_name = data.get("anim")
        if anim_name and anim_name in _ANIM_PRESETS:
            ap = _ANIM_PRESETS[anim_name]
            self._cfg["animations.enabled"]    = ap["enabled"]
            self._cfg["animations.beziers"]    = list(ap["beziers"])
            self._cfg["animations.animations"] = list(ap["animations"])
            self._cfg["_active_preset"]        = anim_name

        # Rebuild UI so all tabs reflect the new values, stay on Presets tab
        presets_idx = next(
            (i for i, (lbl, _) in enumerate(
                [("  Presets", None), ("  Appearance", None), ("  Animations", None),
                 ("  Input", None), ("  Monitors", None), ("  Keybindings", None),
                 ("  Rules", None), ("  Autostart", None), ("  Environment", None),
                 ("  Plugins", None), ("  Scripts", None), ("  About", None)]
            ) if lbl == "  Presets"),
            0
        )
        for child in self.get_children():
            self.remove(child)
        self._build_ui()
        self.show_all()
        self._nb.set_current_page(presets_idx)

        self._status(f'Preset "{name}" loaded — review each tab and click Apply to save')


# ── entry point ────────────────────────────────────────────────────────────────

def main():
    app = VsHyprland()
    Gtk.main()


if __name__ == "__main__":
    main()
