def build_binds(cfg, orig):
    header_m = re.match(r'((?:#[^\n]*\n|\n)*)', orig)
    header = header_m.group(1) if header_m else ""
    lines = [header.rstrip(), ""]
    for var, val in cfg["variables"].items():
        lines.append(f"{var} = {val}")
    lines.append("")
    for b in cfg["binds"]:
        params = f", {b['params']}" if b['params'] else ""
        lines.append(f"{b['type']} = {b['mods']}, {b['key']}, {b['dispatcher']}{params}")
    return "\n".join(lines) + "\n"

def build_rules(cfg, orig):
    header_m = re.match(r'((?:#[^\n]*\n|\n)*)', orig)
    header = header_m.group(1) if header_m else ""
    lines = [header.rstrip(), ""]
    for wr in cfg["windowrules"]:
        lines.append("windowrule {")
        for k, v in wr.items():
            lines.append(f"    {k} = {v}")
        lines.append("}")
        lines.append("")
    for lr in cfg["layerrules"]:
        lines.append(f"layerrule = {lr['rule']}, {lr['namespace']}")
    if cfg["blurls"]:
        lines.append("")
        for bl in cfg["blurls"]:
            lines.append(f"blurls = {bl}")
    return "\n".join(lines) + "\n"

def build_autostart(cfg, orig):
    header_m = re.match(r'((?:#[^\n]*\n|\n)*)', orig)
    header = header_m.group(1) if header_m else ""
    lines = [header.rstrip(), ""]
    for entry in cfg["autostart"]:
        prefix = "" if entry["enabled"] else "# "
        name   = entry.get("name", "").strip()
        suffix = f"  # {name}" if name else ""
        lines.append(f"{prefix}exec-once = {entry['cmd']}{suffix}")
    return "\n".join(lines) + "\n"

def build_env(cfg, orig):
